<% content_for :head do %><title>Settings — Enliterator</title><% end %>

<h1>Settings</h1>
<p class="muted" style="max-width:64ch">
  The configuration this enliteration runs under — the org chart that decides how much mind to bring to
  each record, and the vocabulary it's been given. Configuration lives in code (the host initializer);
  this is a read-only window onto it. The one thing that <em>accumulates</em> at runtime — the approved
  vocabulary — is governed on <%= link_to "Requests", suggestions_path %>.
</p>

<h2>Facets <span class="subtitle">— roles, and the capability assigned to each</span></h2>
<div class="card">
  <% if @facets.any? %>
    <table>
      <tr><th>facet (role)</th><th>tier</th><th>escalation climb</th><th>vocabulary</th><th>required</th></tr>
      <% @contracts.each do |c| %>
        <% approved_n = c[:terms].count { |k| k[:approved] } %>
        <tr>
          <td><strong><%= c[:facet] %></strong><% if c[:origin] && c[:origin] != "root" %> <span class="chip" title="declared in this context"><%= c[:origin] %></span><% end %></td>
          <td><span class="chip tier"><%= c[:tier] %></span></td>
          <td class="mono"><%= c[:climb].join(" → ") %></td>
          <td>
            <% if c[:terms].any? %>
              <%= c[:terms].size %> term<%= "s" if c[:terms].size != 1 %><% if approved_n.positive? %> <span class="muted">(<%= approved_n %> authorized)</span><% end %>
            <% else %>
              <span class="muted">open (no controlled terms)</span>
            <% end %>
          </td>
          <td class="samples"><%= c[:required].any? ? c[:required].join(", ") : "—" %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p class="muted">No staffing policy configured — the default routes every facet to
      <code><%= @policy.ladder.first || "cheap" %></code>. Declare facets with
      <code>Enliterator::Staffing::Policy</code> in your initializer.</p>
  <% end %>
</div>

<h2>Vocabulary <span class="subtitle">— the controlled vocabulary per facet, code + what's accrued</span></h2>
<% if @approved_live.positive? %>
  <p class="muted samples"><strong><%= @approved_live %></strong> curator-authorized term<%= "s" if @approved_live != 1 %> are <span class="badge-live">live</span> across these facets — in force in the vocabulary the model sees, but not yet codified in the policy. Codify them from <%= link_to "Requests", suggestions_path %>.</p>
<% end %>
<div class="row">
  <% @contracts.each do |c| %>
    <% next if c[:terms].empty? %>
    <div class="card">
      <div><strong><%= c[:facet] %></strong> <span class="chip tier"><%= c[:tier] %></span></div>
      <table style="margin-top:.5rem">
        <% c[:terms].each do |k| %>
          <tr>
            <td style="width:40%"><code><%= k[:term] %></code><% if k[:approved] %> <span class="badge-live" title="curator-approved; live but not codified">live</span><% end %></td>
            <td class="samples"><%= k[:description] %></td>
          </tr>
        <% end %>
      </table>
    </div>
  <% end %>
  <% if @contracts.all? { |c| c[:terms].empty? } %>
    <div class="card"><span class="muted">No facet is under a contract — all keys are open. Bind a controlled vocabulary with <code>facet(name, tier:, keys:)</code>.</span></div>
  <% end %>
</div>

<h2>Routing &amp; capability</h2>
<div class="card">
  <table>
    <tr><th style="width:34%">setting</th><th>value</th></tr>
    <tr><td>LLM gateway</td><td class="mono"><%= @config.gateway_base_url %>
      <% if @gateway_ready %><span class="chip tier">key configured</span>
      <% else %><span class="warn">no key — falls back to the injected adapter</span><% end %></td></tr>
    <tr><td>Escalation ladder</td><td class="mono"><%= @policy.ladder.any? ? @policy.ladder.join(" → ") : "—" %></td></tr>
    <tr><td>Escalation threshold</td><td>confidence &lt; <strong><%= @policy.escalation_threshold %></strong> escalates</td></tr>
    <tr><td>Max promotions / tend</td><td><%= @policy.max_promotions %></td></tr>
    <tr><td>Verify floor</td><td>only <code><%= @policy.verify_floor || "—" %></code> and above may mint <code>verified</code> claims</td></tr>
    <tr><td>Embedding tier</td><td><code><%= @policy.embedding_alias || "—" %></code> · <%= @config.default_embedding_dimensions %> dims</td></tr>
    <tr><td>Conversation tier</td><td><code><%= @conversation_tier_effective %></code><%= " (resolved)" unless @config.conversation_tier %></td></tr>
    <tr><td>On-prem-only tiers</td><td class="mono"><%= @policy.on_prem_tier_list.any? ? @policy.on_prem_tier_list.join(", ") : "none" %></td></tr>
    <tr><td>Context caps</td><td class="mono"><%= @policy.context_caps.any? ? @policy.context_caps.map { |t, n| "#{t}=#{n}" }.join("  ") : "none" %></td></tr>
  </table>
</div>

<h2>Vocabulary governance <span class="subtitle">— how the considerer decides</span></h2>
<div class="card">
  <table>
    <tr><th style="width:34%">setting</th><th>value</th></tr>
    <tr><td>Considerer tier</td><td><code><%= @considerer_tier_effective %></code><%= " (resolved)" unless @config.considerer_tier %></td></tr>
    <tr><td>Autonomy</td><td>
      <code><%= @config.considerer_autonomy %></code>
      <span class="muted">— <%= @config.considerer_autonomy == :auto_safe ? "auto-applies synonym maps + confident rejects; holds approvals for you" : "holds every verdict as a recommendation" %></span></td></tr>
    <tr><td>Auto-apply confidence floor</td><td>≥ <strong><%= (@config.considerer_min_confidence.to_f * 100).round %>%</strong> to auto-map / auto-reject</td></tr>
    <tr><td>Approved keys go live</td><td>
      <% if @config.apply_approved_keys %><span class="chip tier">on</span> <span class="muted">— an approved key joins the effective contract immediately</span>
      <% else %><span class="chip">off</span> <span class="muted">— approvals stay advisory (codify by hand)</span><% end %></td></tr>
  </table>
</div>

<h2>Tending behavior</h2>
<div class="card">
  <table>
    <tr><th style="width:34%">setting</th><th>value</th></tr>
    <tr><td>Models tended</td><td class="mono"><%= @models.any? ? @models.join(", ") : "none yet" %></td></tr>
    <tr><td>Default tending facets</td><td class="mono"><%= Array(@config.tending_facets).join(", ") %></td></tr>
    <tr><td>Stale after</td><td><%= @config.stale_after.inspect %> <span class="muted">— the heartbeat's safety-net sweep (v0.15: change events, not age, drive re-tending)</span></td></tr>
    <tr><td>Scheduled-walk batch</td><td><%= @config.tend_batch_size %> records / run</td></tr>
    <tr><td>Job queue</td><td class="mono"><%= @config.queue_name %></td></tr>
    <tr><td>Suggestion sink</td><td><%= @config.suggestion_sink ? "configured (proposals forwarded)" : "local only" %></td></tr>
    <tr><td>Null-LLM guard</td><td>
      <% if @config.allow_null_llm %><span class="warn">permitted</span> <span class="muted">— a real tend may resolve to the inert Null adapter (tests only)</span>
      <% else %><span class="chip tier">enforced</span> <span class="muted">— a real tend resolving to Null raises instead of writing a phantom visit</span><% end %></td></tr>
  </table>
</div>

<h2>Heartbeat <span class="subtitle">— the event-driven tending cycle (v0.15)</span></h2>
<div class="card">
  <table>
    <tr><th style="width:34%">setting</th><th>value</th></tr>
    <tr><td>Per-cycle token budget</td><td><strong><%= number_with_delimiter(@config.heartbeat_budget_tokens) %></strong> <span class="muted">— enforced on ACTUAL tokens in sync mode; the cycle cannot exceed its appropriation</span></td></tr>
    <tr><td>Change share</td><td><%= (@config.heartbeat_change_share.to_f * 100).round %>% <span class="muted">— reserved for change-triggered re-tends (source change → neighborhood → vocabulary); the rest, plus anything unused, goes to the untended frontier</span></td></tr>
    <tr><td>Neighborhood threshold</td><td><%= @config.heartbeat_neighbor_threshold %> <span class="muted">— context-mates tended since a record's last visit before it re-reads (the v0.14 measured signal)</span></td></tr>
    <tr><td>Condition survey</td><td>
      <% if Enliterator::Condition.probes_registered? %>
        <span class="chip tier"><%= Enliterator::Condition.registry.size %> probe(s)</span>
        <span class="mono"><%= Enliterator::Condition.registry.keys.join(", ") %></span>
        <span class="muted">— <%= @config.heartbeat_survey_budget_ms %>ms/cycle; catalog note at <code><%= @config.condition_claim_scope %></code></span>
      <% else %>
        <span class="muted">no probes registered — the collection is not shelf-reading itself yet</span>
      <% end %></td></tr>
    <tr><td>Source-change test</td><td>
      <% if @config.heartbeat_source_changed %><span class="chip tier">host-supplied</span> <span class="muted">— the host decides when a record's text has really changed</span>
      <% else %><span class="chip">default</span> <span class="muted">— record updated_at vs the last visit's start (approximate; override with <code>heartbeat_source_changed</code>)</span><% end %></td></tr>
    <tr><td>Last cycle</td><td>
      <% if @last_heartbeat %>
        #<%= @last_heartbeat.id %> · <%= @last_heartbeat.mode %> · <%= @last_heartbeat.started_at.strftime("%Y-%m-%d %H:%M") %>
        <% if @last_heartbeat.finished? %>
          <% if @last_heartbeat.error %><span class="warn">aborted — <%= @last_heartbeat.error %></span>
          <% else %><span class="muted">— planned <%= @last_heartbeat.planned_count %><% if @last_heartbeat.tokens_spent["total"] %>, spent <%= number_with_delimiter(@last_heartbeat.tokens_spent["total"]) %> tokens<% end %></span><% end %>
        <% else %><span class="warn">still open<%= " — likely crashed" if @last_heartbeat.started_at < 6.hours.ago %></span><% end %>
      <% else %>
        <span class="muted">never run — tending is hand-cranked until the host schedules <code>enliterator:heartbeat</code></span>
      <% end %></td></tr>
  </table>
</div>

<p class="muted samples" style="margin-top:1.5rem; border-top:1px solid var(--line); padding-top:.75rem; max-width:64ch">
  Read-only. Facets, tiers, and the ladder are code (the host initializer); the approved vocabulary
  accrues through <%= link_to "Requests", suggestions_path %>. This is the configuration of the whole
  collection.
</p>

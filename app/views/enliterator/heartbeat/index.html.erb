<%# The pulse monitor (v0.16). Trigger a cycle, watch it live. Everything the
    monitor renders derives from the ledger row + the visits it stamps as they
    happen — no new state, no websockets, a 2s poll of /heartbeat/pulse/:id. %>
<style>
  .pulse-track { height: 10px; background: var(--line); border-radius: 6px; overflow: hidden; margin: .5rem 0 .3rem; }
  .pulse-fill  { height: 100%; width: 0%; background: var(--accent); border-radius: 6px; transition: width .6s ease; }
  .pulse-stats { display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: baseline; }
  .pulse-banner { padding: .5rem .8rem; border-radius: 8px; margin-top: .6rem; font-size: .9rem; display: none; }
  .pulse-banner.warn-bg { background: var(--warn-soft); color: var(--warn); display: block; }
  .ticker { list-style: none; margin: .6rem 0 0; padding: 0; font-size: .82rem; max-height: 16rem; overflow-y: auto; }
  .ticker li { padding: .25rem 0; border-top: 1px solid var(--line); }
  .ticker li:first-child { border-top: none; }
</style>

<h1>Heartbeat <span class="subtitle">— one metabolic cycle: plan → tend → consider → ledger</span></h1>
<p class="muted">
  The heartbeat tends the <strong>whole collection — every context, one budget</strong>; the context
  selector scopes the other surfaces, never this one. Each cycle works the untended frontier first,
  re-reads only records whose world changed, and stops at its token appropriation.
</p>

<% if @running %>
  <%# ── monitor mode — a cycle is live; poll it ─────────────────────────── %>
  <h2>Cycle #<%= @running.id %> <span class="chip tier">running</span>
      <span class="subtitle">— started <%= @running.started_at.strftime("%H:%M:%S") %>, budget <%= number_with_delimiter(@running.budget_tokens) %> tokens</span></h2>
  <div class="card" id="monitor"
       data-pulse-url="<%= heartbeat_pulse_path(@running.id) %>"
       data-planned="<%= @running.planned_count %>"
       data-budget="<%= @running.budget_tokens %>">
    <div class="pulse-track"><div class="pulse-fill" id="bar"></div></div>
    <div class="pulse-stats">
      <span><strong id="items">0</strong> <span class="muted">of <%= @running.planned_count %> item(s)</span></span>
      <span class="muted"><span id="tokens">0</span> / <%= number_with_delimiter(@running.budget_tokens) %> tokens</span>
      <span id="reasons"></span>
      <span class="muted samples" id="phase"></span>
    </div>
    <div class="pulse-banner" id="banner"></div>
    <div id="finish"></div>
    <ul class="ticker" id="ticker"></ul>
  </div>

<% else %>
  <%# ── plan + trigger mode ─────────────────────────────────────────────── %>
  <h2>Next cycle <span class="subtitle">— what one beat would do right now</span></h2>
  <div class="card">
    <% if @plan.items.any? %>
      <div>
        <% @plan.counts.sort.each do |reason, n| %>
          <span class="chip"><%= reason %> <strong><%= n %></strong></span>
        <% end %>
        <span class="muted">est <%= number_with_delimiter(@plan.est_total) %> of <%= number_with_delimiter(@plan.budget) %> tokens</span>
      </div>
      <table style="margin-top:.6rem">
        <tr><th>lane</th><th>work</th></tr>
        <% @plan.lane_counts.sort.each do |lane, reasons| %>
          <tr><td class="mono"><%= lane %></td>
              <td><%= reasons.sort.map { |r, n| "#{r} #{n}" }.join(" · ") %></td></tr>
        <% end %>
      </table>
    <% else %>
      <span class="muted">Nothing to do — the collection is current.</span>
    <% end %>
    <div class="muted" style="margin-top:.5rem"><%= @plan.horizon_line %></div>
    <% if @plan.warnings.any? %>
      <details style="margin-top:.4rem"><summary class="muted samples"><%= @plan.warnings.size %> planner note(s)</summary>
        <ul class="muted samples" style="margin:.3rem 0 0 1rem">
          <% @plan.warnings.each do |w| %><li><%= w %></li><% end %>
        </ul>
      </details>
    <% end %>
  </div>

  <%# The POST holds the plan scan (seconds) — the disable makes the pause read
      as work. setTimeout so the disabled button's submission still completes. %>
  <%= form_with url: heartbeat_beat_path, method: :post,
                html: { style: "margin-top:.8rem",
                        onsubmit: "var b=document.getElementById('beat-btn'); setTimeout(function(){ b.disabled=true; b.textContent='planning…'; }, 0); return true;" } do |f| %>
    <div class="card" style="display:flex; gap:.8rem; align-items:center; flex-wrap:wrap">
      <label class="muted" for="budget">Token budget for this cycle</label>
      <input type="number" name="budget" id="budget" min="1" class="field"
             value="<%= @default_budget %>" style="width:9rem">
      <button type="submit" id="beat-btn" class="btn btn-primary">Beat now</button>
      <span class="muted samples">sync — runs server-side, enforced on actual tokens; watch it here</span>
    </div>
  <% end %>
<% end %>

<h2>Recent cycles</h2>
<div class="card">
  <% if @recent.any? %>
    <table>
      <tr><th>#</th><th>started</th><th>mode</th><th>duration</th><th>planned</th><th>executed</th><th>tokens</th><th></th></tr>
      <% @recent.each do |hb| %>
        <tr>
          <td><%= hb.id %></td>
          <td class="mono"><%= hb.started_at.strftime("%Y-%m-%d %H:%M") %></td>
          <td><%= hb.mode %></td>
          <td><%= hb.finished? ? "#{(hb.finished_at - hb.started_at).round}s" : "—" %></td>
          <td><%= hb.planned_count %></td>
          <td>
            <% if hb.finished? %>
              <%= (hb.executed || {}).map { |r, c| "#{r} #{c.reject { |_, v| v.to_i.zero? }.map { |k, v| "#{k} #{v}" }.join(', ')}" }.join(" · ").presence || "—" %>
            <% elsif hb == @running %>
              <span class="chip tier">running</span>
            <% else %>
              <span class="warn">still open — likely crashed (force starts a new cycle)</span>
            <% end %>
          </td>
          <td><%= hb.tokens_spent.is_a?(Hash) && hb.tokens_spent["total"] ? number_with_delimiter(hb.tokens_spent["total"]) : "—" %></td>
          <td>
            <% if hb.error %><span class="warn" title="<%= hb.error %>">aborted</span><% end %>
            <% if hb.finished? && hb.warnings.any? %><span class="muted samples" title="<%= hb.warnings.join("\n") %>"><%= hb.warnings.size %> note(s)</span><% end %>
          </td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <span class="muted">No cycles yet — this button ends the hand-cranked era.</span>
  <% end %>
</div>

<% if @running %>
<script>
(function () {
  var el = document.getElementById("monitor");
  var pulseUrl = el.getAttribute("data-pulse-url");
  var planned  = parseInt(el.getAttribute("data-planned"), 10) || 0;
  var bar = document.getElementById("bar"), items = document.getElementById("items"),
      tokens = document.getElementById("tokens"), reasons = document.getElementById("reasons"),
      phase = document.getElementById("phase"), banner = document.getElementById("banner"),
      finish = document.getElementById("finish"), ticker = document.getElementById("ticker");
  var seen = {}, failures = 0;

  function fmt(n) { return (n || 0).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ","); }

  function render(p) {
    failures = 0;
    banner.className = "pulse-banner";        // clear any unreachable/stall banner
    items.textContent = p.items_done;
    tokens.textContent = fmt(p.tokens_total);
    bar.style.width = planned > 0 ? Math.min(100, Math.round(p.items_done / planned * 100)) + "%" : "0%";

    var chips = [];
    Object.keys(p.planned_by_reason || {}).sort().forEach(function (r) {
      chips.push(r + " " + (p.done_by_reason[r] || 0) + "/" + p.planned_by_reason[r]);
    });
    reasons.textContent = chips.join(" · ");

    // The visit ticker — newest first, keyed by visit id. A row appears the
    // moment its visit OPENS (status running, no confidence yet) and updates
    // in place as the visit finishes — the heartbeat visibly thinking.
    // Escalation pairs (cheap then quality on the same record) read as the
    // loop deciding to bring more mind — the most demo-compelling thing the
    // engine does.
    (p.last_visits || []).slice().reverse().forEach(function (v) {
      var li = seen[v.id];
      var fresh = !li;
      if (fresh) { li = document.createElement("li"); seen[v.id] = li; }
      li.innerHTML = '<span class="muted samples">' + new Date(v.at).toLocaleTimeString() + '</span> ' +
        '<span class="chip">' + v.reason + '</span> ' +
        '<strong>' + v.facet + '</strong>' +
        '<span class="muted">@' + v.context_key + '</span> ' +
        '<span class="mono">' + v.tendable + '</span> ' +
        '<span class="chip tier">' + (v.tier || "") + '</span>' +
        (v.status === "failed"  ? ' <span class="warn">failed</span>'
         : v.status === "running" ? ' <span class="muted samples">tending…</span>'
         : ' <span class="muted">conf ' + (v.confidence == null ? "—" : v.confidence) + '</span>') +
        (v.tokens ? ' <span class="muted samples">' + fmt(v.tokens) + ' tok</span>' : '');
      if (fresh) ticker.insertBefore(li, ticker.firstChild);
    });

    if (p.finished) {
      phase.textContent = "";
      bar.style.width = "100%";
      var html = p.error
        ? '<div class="pulse-banner warn-bg" style="display:block">Cycle aborted — ' + p.error + '</div>'
        : '<div class="muted" style="margin-top:.5rem"><strong>Cycle finished.</strong> ' + fmt(p.tokens_total) + ' tokens spent.' +
          ((p.warnings || []).length ? ' ' + p.warnings.length + ' note(s) on the ledger.' : '') + '</div>';
      finish.innerHTML = html;
      // Show the outcome INLINE first (an abort must be loud), then reload
      // into plan+trigger mode with the finished row in the recent table.
      setTimeout(function () { location.reload(); }, 4000);
      return;
    }

    if (planned > 0 && p.items_done >= planned) {
      phase.textContent = "running considerer…";   // governance closes the cycle
    } else if (p.stalled) {
      banner.className = "pulse-banner warn-bg";
      banner.innerHTML = "No activity for several minutes — the cycle may have crashed (server restart?). " +
        "It will show as crash evidence below; force a new cycle: " +
        '<form method="post" action="<%= heartbeat_beat_path %>" style="display:inline">' +
        '<input type="hidden" name="authenticity_token" value="' + ((document.querySelector('meta[name=csrf-token]') || {}).content || "") + '">' +
        '<input type="hidden" name="force" value="1">' +
        '<button type="submit" class="btn btn-sm">Force new cycle</button></form>';
    } else {
      phase.textContent = "";
    }
    setTimeout(tick, 2000);
  }

  function tick() {
    fetch(pulseUrl, { headers: { "Accept": "application/json" } })
      .then(function (r) { if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(render)
      .catch(function () {
        // The poll loop must survive a server restart mid-cycle — the exact
        // scenario this page exists to make visible.
        failures += 1;
        if (failures >= 5) {
          banner.className = "pulse-banner warn-bg";
          banner.textContent = "Server unreachable — still trying. If it restarted, the cycle died with it and will show as crash evidence.";
        }
        setTimeout(tick, 2000);
      });
  }

  tick();
})();
</script>
<% end %>

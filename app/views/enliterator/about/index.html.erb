    <nav class="about-toc" aria-label="On this page">
      <div class="toc-label">On this page</div>
      <ol>
        <li class="toc-h1"><a href="#what-is-enliterator">What is Enliterator?</a></li>
        <li class="toc-h2"><a href="#the-missing-word">The missing word</a></li>
        <li class="toc-h2"><a href="#what-tended-means">What "tended" means</a></li>
        <li class="toc-h2"><a href="#compounding-attention">Compounding attention</a></li>
        <li class="toc-h2"><a href="#how-it-works">How it works</a></li>
        <li class="toc-h2"><a href="#the-pulse">The pulse</a></li>
        <li class="toc-h2"><a href="#the-conscience-is-human">The conscience is human</a></li>
        <li class="toc-h2"><a href="#for-a-collection-like-this-one">For a collection like this one</a></li>
        <li class="toc-h2"><a href="#the-four-surfaces">The surfaces</a></li>
      </ol>
    </nav>
  </aside>

  <%# ── Main prose column ─────────────────────────────────────────────────── %>
  <div class="about-content">

    <h1 id="what-is-enliterator">What is Enliterator?</h1>

    <p class="lede">
      Enliterator confers <strong>literacy</strong> on a collection. Not search — literacy: the capacity to
      participate in inquiry, to accumulate understanding, to compound across visits the way a reader
      compounds across books. A searchable archive can find words. An <em>enliterated</em> collection can
      think about itself.
    </p>

    <%# The page demonstrates its own thesis: it speaks about the collection it's mounted on. %>
    <% if @stats && @stats[:visits].to_i.positive? %>
      <div class="stats-strip">
        <div class="stats-eyebrow">This collection, right now</div>
        <div class="stats-grid">
          <div class="stat-cell">
            <span class="stat-num"><%= number_with_delimiter @stats[:tended_records] %></span>
            <span class="stat-label">records tended</span>
          </div>
          <div class="stat-cell">
            <span class="stat-num"><%= number_with_delimiter @stats[:visits] %></span>
            <span class="stat-label">tending visits</span>
          </div>
          <div class="stat-cell">
            <span class="stat-num"><%= number_with_delimiter @stats[:live_claims] %></span>
            <span class="stat-label">things it knows</span>
          </div>
          <div class="stat-cell">
            <span class="stat-num"><%= @stats[:facets].size %></span>
            <span class="stat-label">facets of inquiry</span>
          </div>
        </div>
        <% if @stats[:facets].any? %>
          <div class="stats-facets">
            <span class="facets-label">Active facets:</span>
            <% @stats[:facets].each do |s| %>
              <span class="facet-chip"><%= s %></span>
            <% end %>
          </div>
        <% end %>
        <% if (@stats[:vocab_resolved].to_i + @stats[:vocab_pending].to_i).positive? %>
          <div class="stats-footer">
            Vocabulary: <strong><%= @stats[:vocab_resolved] %></strong> requests resolved &middot;
            <%= @stats[:vocab_pending] %> still open.
            The ontology tends itself — see <%= link_to "Requests", suggestions_path %>.
          </div>
        <% end %>
      </div>
      <p class="muted samples" style="margin-top:.5rem; margin-bottom:1.75rem">
        These numbers are live. Everything below explains how they came to be, and what they become over time.
      </p>
    <% end %>

    <h2 id="the-missing-word">The missing word</h2>
    <p>
      A child is born with the hardware for language, but it sits inert until someone opens the door —
      points at marks, ties them to sounds, ties sounds to the accumulated record of human thought. After
      that door opens, every book changes how they read the next one. Literacy isn't a skill; it's access
      to a loop that <strong>compounds across a lifetime</strong>. We decided that withholding it from a
      child capable of it is not a missing feature — it's neglect.
    </p>
    <p>
      There was no word for the same thing happening to <em>data</em>: a record gaining the capacity to
      participate in meaningful inquiry — not searched once, but <strong>tended</strong>, accumulating
      understanding across visits. So we named it. <strong>Enliteracy</strong>: to put into literacy. The
      prefix does the work — enable, enrich, enlighten. Each is a threshold crossed. This is the door, for
      a collection.
    </p>

    <h2 id="what-tended-means">What "tended" means</h2>
    <p>
      Most systems stop at <em>searchable</em>: embeddings, a vector index, questions in natural language.
      Useful — and the bare minimum. Searchable is to literate what recognizing letters is to reading. You
      can find the words; you don't yet understand the sentences.
    </p>
    <p>
      Enliterator runs a maintenance loop on each record — but the loop runs through a <strong>language
      model</strong>, not a heuristic. A cron job inspects and flags; it never learns. When the loop runs
      through language, each visit brings the whole compressed geometry of human thought to bear on
      <em>this</em> record in <em>this</em> state. The tenth visit isn't smarter because it remembers the
      previous nine — any database remembers. It's smarter because the corpus meets the accumulated history
      of this particular record, and the intersection produces understanding neither contained alone. That
      is what the child gets when the door opens: not a loop of looking at marks, but marks connected to a
      depth of thought no single lifetime could hold. The record gains the same connection.
    </p>

    <h2 id="compounding-attention">Compounding attention — now, and over time</h2>
    <p>
      This is the whole point, so it's worth being precise about what changes the day you turn it on, and
      what changes only with time.
    </p>
    <div class="duo-row">
      <div class="card">
        <div class="card-head"><strong>Now</strong> <span class="chip">first pass</span></div>
        <ul>
          <li>A dormant archive becomes <strong>legible</strong>. A record that was only findable becomes
            readable — it carries what it argues, why it matters, who made it, what it connects to.</li>
          <li>The collection gains a <strong>self-portrait</strong>: it knows its own vocabulary, its gaps,
            its shape — and can answer questions grounded in its own records, with provenance.</li>
          <li><strong>First attention</strong> reaches records no curator ever had time for. The triage that
            left most of a collection untouched is no longer forced.</li>
        </ul>
      </div>
      <div class="card">
        <div class="card-head"><strong>Over time</strong> <span class="chip">the compounding</span></div>
        <ul>
          <li>Understanding <strong>deepens</strong>, not just persists. Each visit meets the record's
            accumulated history; claims are refined, not duplicated.</li>
          <li>The vocabulary <strong>converges</strong>. Synonyms fold together, noise is rejected, genuine
            new concepts become permanent — the collection's language sharpens toward what actually matters.</li>
          <li>The investment <strong>compounds</strong>. A stronger model or a richer vocabulary re-tends the
            whole collection and lifts all of it at once; cross-record connections thicken into a graph. The
            collection knows more next year than it does today.</li>
          <li>And this is <strong>measured, not assumed</strong>: every record carries its own
            "understanding over time" — visit-by-visit diffs of what it knows — and a blind judge
            compares earlier vs later understanding. If a re-visit merely restates, the system can
            tell; deepening has to be earned.</li>
        </ul>
      </div>
    </div>
    <p>
      And the economics flip. When the cost of examining one record drops low enough, the question is no
      longer <em>"can we afford to look at this?"</em> but <em>"can we afford <strong>not</strong> to?"</em>
      A collection of 160,000 works left intellectually dormant was once a resource constraint. When the
      constraint lifts, what remains is a choice.
    </p>

    <h2 id="how-it-works">How it works</h2>
    <p>The machinery, plainly — this is what the engine does today:</p>
    <div class="card">
      <table class="mech-table">
        <tr>
          <td class="mech-key"><strong>Facets are roles</strong></td>
          <td>Each facet of understanding is its own job<%= @stats && @stats[:facets].any? ? " — here: #{@stats[:facets].join(', ')}".html_safe : "" %>. A record is tended once per facet, so "what it argues" and "who wrote it" don't compete in one pass.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>Tiers are capability</strong></td>
          <td>A cheap model does the first pass; the loop escalates to a stronger one only when confidence is low, with a verify floor guarding the result. You pay for capability exactly where it's needed.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>Claims, reconciled</strong></td>
          <td>Each visit proposes claims and reconciles them against what's already known — add, update, delete, or leave alone — so re-tending <em>deepens</em> a record instead of duplicating it. Authoritative host facts are locked and never re-derived.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>A vocabulary that tends itself</strong></td>
          <td>The model can't invent terms — it proposes them. Proposals accumulate <em>pressure</em> across records; an agent reads the whole field and renders verdicts (fold synonyms, reject noise, hold genuine new concepts for a human). Approved terms go <strong>live</strong>, and the loop converges on the genuinely contested ones.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>Collections within collections</strong></td>
          <td>A <em>context</em> is a lens: an item belongs to the whole collection and to any number of labeled sub-collections, each with its own facets and vocabulary, inheriting its ancestors' — the finding-aid principle. An Executive Order is read for its <em>supersession graph</em>; a CRS report for its <em>issue for Congress</em>; neither lens contaminates the other, and within a context a record reads against its fellow members, not the undifferentiated whole.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>Provenance throughout</strong></td>
          <td>Every claim knows how it came to be known — which model, which visit, what it was attributed to. Nothing is asserted without a trail.</td>
        </tr>
        <tr>
          <td class="mech-key"><strong>A smoke alarm</strong></td>
          <td>Tending health and spend are visible per facet, so a silent failure can't masquerade as success.</td>
        </tr>
      </table>
    </div>

    <h2 id="the-pulse">The pulse</h2>
    <p>
      For its first fourteen versions this engine was <strong>hand-cranked on purpose</strong> — every pass
      watched, because supervision is how you earn the right to automate. Then we ran the experiment: cohorts
      re-tended under controlled conditions, every diff measured, a blind judge scoring earlier against later.
      The verdict was precise. Re-visiting is safe — but re-reading a record whose surroundings haven't changed
      teaches nothing. What deepens understanding is <em>change</em>: new neighbors tended, a vocabulary that
      grew, a source that moved. And nothing rivals <strong>first attention</strong> — the untended shelf is
      where almost all the learning is.
    </p>
    <p>
      So the heartbeat that replaced the hand-crank is <strong>event-driven, not scheduled</strong>. Each cycle
      it works the untended frontier first, re-reads only the records whose world actually changed, and keeps
      the old "re-tend everything every N days" rule only as a safety net. Two instruments replace the watching
      eye: a <strong>spend cap enforced on actual tokens</strong> — a cycle cannot exceed its appropriation —
      and a <strong>ledger</strong>: every cycle is a record of what it planned, why each item was chosen, and
      what it cost; every visit points back to the cycle that caused it. The schedule itself has provenance.
      And the plan always shows its <strong>horizon</strong> — "35,000 records remaining ≈ 700 cycles at this
      budget" — so the pace of a collection's enliteracy is a decision someone owns, never an accident.
      The pulse is also <strong>pressable</strong>: the <%= link_to "Heartbeat", heartbeat_path %> surface
      triggers one cycle and shows it beating — each visit landing on the ledger as it happens.
    </p>

    <h2 id="the-conscience-is-human">The conscience is human</h2>
    <p>
      At Burning Man there's a saying: if you make eye contact with trash, it's yours — not because you
      made it, because you <em>saw</em> it. The obligation doesn't come from perception; it comes from the
      relationship the gaze creates. Once you see it, you can't unsee it, and the world fills with things
      asking for grace.
    </p>
    <p>
      The tending system has no ethics. It has a schedule and a credit card. It runs because someone decided
      the output justified the cost; cancel the card and it stops. The <strong>conscience belongs to the
      person who saw the collection sitting dormant and couldn't look away</strong> — the one who can see the
      need and authorize the spend. Society funds a child's literacy with buildings and teachers' salaries.
      The enliteracy of a collection is the same shape: someone decides the tending is worth paying for. The
      engine is infrastructure. The decision is yours.
    </p>

    <h2 id="for-a-collection-like-this-one">For a collection like this one</h2>
    <p>
      A homeland-security thesis archive is exactly the case that rewards tending. Each thesis is a dense
      argument that took an author a year to make — and then it sits, findable by keyword, rarely read.
      Tended, every thesis declares what it contributes, what it found, where it's limited, who wrote it,
      and which other work it speaks to. The collection becomes a <strong>living body of scholarship</strong>
      that can be questioned as a whole, that surfaces the connections no single reader would find, and that
      grows sharper every time the loop runs. Dormant becomes legible; an archive becomes a colleague.
    </p>

    <h2 id="the-four-surfaces">The surfaces</h2>
    <div class="surfaces-grid">
      <div class="card">
        <span class="surface-title"><%= link_to "Status", root_path %></span>
        <span class="surface-desc">The self-portrait — per-facet health, the vocabulary it uses, the connection graph, and drill-down into any single tended record.</span>
      </div>
      <div class="card">
        <span class="surface-title"><%= link_to "Chat", conversation_path %></span>
        <span class="surface-desc">Converse with the enliteration — answers grounded in the collection's own records, with source links back to Status.</span>
      </div>
      <div class="card">
        <span class="surface-title"><%= link_to "Requests", suggestions_path %></span>
        <span class="surface-desc">Govern the vocabulary — review the terms the model wants, approve / map / reject, and watch the loop converge.</span>
      </div>
      <div class="card">
        <span class="surface-title"><%= link_to "Contexts", contexts_path %></span>
        <span class="surface-desc">Collections within collections — the context tree, each lens's facets and members; the nav switcher views every surface through any of them.</span>
      </div>
      <div class="card">
        <span class="surface-title"><%= link_to "Heartbeat", heartbeat_path %></span>
        <span class="surface-desc">The pulse, pressable — trigger one tending cycle and watch it live: the queue, the spend against its budget, every visit as it lands on the ledger.</span>
      </div>
      <div class="card">
        <span class="surface-title"><%= link_to "Settings", settings_path %></span>
        <span class="surface-desc">The configuration — the org chart of facets and tiers, the effective vocabulary, and how the considerer decides.</span>
      </div>
      <div class="card">
        <span class="surface-title">About</span>
        <span class="surface-desc">This page. What we're building and why — kept current as the engine grows.</span>
      </div>
    </div>

    <p class="about-colophon">
      Living document &middot; reflects Enliterator as of <strong>June 2026</strong> (v0.15 — the
      heartbeat: event-driven tending on a budget and a ledger, specified by v0.14's measured verdict;
      v0.13 contexts; v0.12 spoke the library's language). Not searchability conferred once —
      <strong>attention that compounds</strong>.
    </p>

  </div><%# /about-content %>
</div><%# /about-layout %>

<script>
(function () {
  // Scrollspy: highlights TOC links as sections enter the viewport.
  // Strategy: IntersectionObserver tracks which headings have passed the top of
  // the page; the most recently-passed heading (highest in document order but
  // not yet below the reading line) is the active one.
  // Respects prefers-reduced-motion for smooth scroll behaviour.

  var prefersReducedMotion = window.matchMedia &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var headingIds = [
    'what-is-enliterator',
    'the-missing-word',
    'what-tended-means',
    'compounding-attention',
    'how-it-works',
    'the-conscience-is-human',
    'for-a-collection-like-this-one',
    'the-four-surfaces'
  ];

  // Smooth-scroll on TOC link click
  document.querySelectorAll('.about-toc a[href^="#"]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      var targetId = link.getAttribute('href').slice(1);
      var target = document.getElementById(targetId);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({
        behavior: prefersReducedMotion ? 'instant' : 'smooth',
        block: 'start'
      });
      history.pushState(null, '', '#' + targetId);
    });
  });

  // ── Scrollspy via getBoundingClientRect on scroll ─────────────────────────
  // This approach is robust regardless of section length: on every scroll we
  // find the last heading whose top edge is at or above 20% from the top of
  // the viewport, and activate it. Cheap because headingIds is tiny (8 items).

  var activeId = null;
  var THRESHOLD = 0.20; // heading must be within top 20% of viewport to activate

  function findActive() {
    var vh = window.innerHeight;
    var line = vh * THRESHOLD; // pixel offset — headings above this line are "past"
    var best = null;
    for (var i = 0; i < headingIds.length; i++) {
      var el = document.getElementById(headingIds[i]);
      if (!el) continue;
      var top = el.getBoundingClientRect().top;
      if (top <= line) {
        best = headingIds[i]; // keep updating — last one wins (furthest down doc)
      }
    }
    return best || headingIds[0];
  }

  function setActive(id) {
    if (id === activeId) return;
    activeId = id;
    document.querySelectorAll('.about-toc a').forEach(function (a) {
      if (a.getAttribute('href') === '#' + id) {
        a.setAttribute('aria-current', 'true');
      } else {
        a.removeAttribute('aria-current');
      }
    });
  }

  // Throttle scroll handler with requestAnimationFrame
  var ticking = false;
  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(function () {
        setActive(findActive());
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });

  // Set initial active state on load
  setActive(findActive());
})();
</script>

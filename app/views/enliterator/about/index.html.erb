    position: sticky;
    top: 1.75rem;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
    padding-right: .25rem;
  }
  .about-toc .toc-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: .7rem;
    padding-left: .6rem;
  }
  .about-toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .about-toc ol li {
    margin: 0;
    padding: 0;
  }
  .about-toc ol li.toc-h1 a {
    font-weight: 600;
    font-size: .82rem;
    padding: .3rem .6rem;
    margin-bottom: .15rem;
  }
  .about-toc ol li.toc-h2 a {
    font-size: .79rem;
    padding: .25rem .6rem .25rem 1.1rem;
    border-left: 2px solid transparent;
  }
  .about-toc a {
    display: block;
    color: var(--muted);
    text-decoration: none;
    border-radius: 4px;
    transition: color .15s, background .15s, border-color .15s;
    line-height: 1.35;
  }
  .about-toc a:hover {
    color: var(--ink);
    background: var(--chip);
    text-decoration: none;
  }
  .about-toc a[aria-current="true"] {
    color: var(--accent);
    border-left-color: var(--accent);
    background: var(--accent-soft);
    font-weight: 600;
  }
  /* H1 toc entry: use accent bg but no left border (it has no indent) */
  .about-toc li.toc-h1 a[aria-current="true"] {

<%# Sigma-backed Atlas viewer. Self-contained by design: vendor bundle, data, styles,
    and client code all live inline so HSDL/Sprockets and dummy/Propshaft both render it
    without engine asset precompile dependencies. %>
<style>
  .atlas-wrap {
    --atlas-bg: #08111d;
    --atlas-panel: #0c1726;
    --atlas-panel-2: #101d2d;
    --atlas-line: rgba(144, 161, 185, .22);
    --atlas-text: #d7e0eb;
    --atlas-muted: #8391a4;
    --atlas-faint: #4d5b6f;
    --atlas-accent: #f2c15f;
    --atlas-danger: #f07f78;
    background:
      radial-gradient(circle at 18% 8%, rgba(242, 193, 95, .10), transparent 24rem),
      radial-gradient(circle at 88% 18%, rgba(83, 214, 186, .08), transparent 28rem),
      linear-gradient(180deg, #091321, var(--atlas-bg));
    border: 1px solid var(--atlas-line, #243244);
    border-radius: 14px;
    overflow: hidden;
    color: var(--atlas-text);
    width: 100%;
    max-width: none;
    min-height: calc(100dvh - 11rem);
    box-shadow: 0 20px 70px rgba(3, 10, 20, .38);
  }
  body.enl-atlas-page main.enl { max-width: none; width: 100%; padding-left: .75rem; padding-right: .75rem; }
  body.enl-atlas-page main.enl > p { max-width: 88rem !important; }
  .atlas-shell { display: block; min-height: calc(100dvh - 11rem); }
  .atlas-main { min-width: 0; display: flex; flex-direction: column; min-height: calc(100dvh - 11rem); }
  /* Stage 1 (the Ego lens): the stage splits into the graph + a ranked neighbor
     list, co-equal and side-swappable; the inspector is a bottom drawer. */
  .atlas-split { display: flex; flex: 1 1 auto; min-height: 0; }
  .atlas-shell.swapped .atlas-split { flex-direction: row-reverse; }
  .atlas-neighbors { flex: 0 0 23rem; min-width: 0; display: flex; flex-direction: column; border-left: 1px solid var(--atlas-line); background: rgba(8,17,29,.8); }
  .atlas-shell.swapped .atlas-neighbors { border-left: 0; border-right: 1px solid var(--atlas-line); }
  .atlas-neighbors[hidden] { display: none; }
  .atlas-neighbors-head { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .56rem .72rem; border-bottom: 1px solid var(--atlas-line); }
  .atlas-neighbors-sort { font: inherit; font-size: .74rem; color: var(--atlas-text); background: rgba(255,255,255,.045); border: 1px solid var(--atlas-line); border-radius: 7px; padding: .12rem .4rem; }
  .atlas-neighbors-list { overflow: auto; padding: .35rem .35rem .8rem; min-height: 0; }
  .atlas-ngrp { color: var(--atlas-accent); text-transform: uppercase; letter-spacing: .09em; font-size: .62rem; font-weight: 800; padding: .55rem .5rem .2rem; }
  .atlas-nrow { display: flex; align-items: baseline; justify-content: space-between; gap: .5rem; width: 100%; text-align: left; font: inherit; color: var(--atlas-text); background: transparent; border: 1px solid transparent; border-radius: 8px; padding: .3rem .5rem; cursor: pointer; }
  .atlas-nrow:hover { background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.08); }
  .atlas-nrow.active { background: rgba(242,193,95,.16); border-color: rgba(242,193,95,.3); }
  .atlas-nrow .nlabel { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .atlas-nrow .nconf { color: var(--atlas-muted); font-variant-numeric: tabular-nums; font-size: .74rem; flex: none; }
  .atlas-neighbors-empty { color: var(--atlas-muted); font-size: .8rem; padding: .8rem .6rem; }
  .atlas-controls { display: flex; gap: .7rem; align-items: center; flex-wrap: wrap; padding: .5rem .75rem; border-bottom: 1px solid var(--atlas-line); background: rgba(8,17,29,.7); font-size: .76rem; color: var(--atlas-muted); }
  .atlas-controls[hidden] { display: none; }
  .atlas-controls label { display: inline-flex; align-items: center; gap: .35rem; }
  .atlas-controls select { color: var(--atlas-text); background: rgba(255,255,255,.045); border: 1px solid var(--atlas-line); border-radius: 7px; padding: .1rem .35rem; font: inherit; font-size: .74rem; }
  .atlas-controls input[type="range"] { accent-color: var(--atlas-accent); }
  .atlas-bar {
    display: grid;
    grid-template-columns: auto minmax(9rem, 18rem) auto auto auto auto 1fr;
    gap: .55rem;
    align-items: center;
    padding: .62rem .75rem;
    background: rgba(8, 17, 29, .86);
    border-bottom: 1px solid var(--atlas-line);
    backdrop-filter: blur(12px);
    font-size: .82rem;
  }
  .atlas-mode { display: inline-flex; align-items: center; gap: .18rem; padding: .16rem; border: 1px solid var(--atlas-line); border-radius: 999px; background: rgba(255,255,255,.035); }
  .atlas-btn, .atlas-chip, .atlas-export {
    font: inherit;
    color: var(--atlas-text);
    border: 1px solid transparent;
    background: transparent;
    border-radius: 999px;
    padding: .28rem .62rem;
    cursor: pointer;
    transition: background .18s ease, border-color .18s ease, color .18s ease, transform .18s ease;
    white-space: nowrap;
  }
  .atlas-btn:hover, .atlas-chip:hover, .atlas-export:hover { background: rgba(255,255,255,.07); border-color: rgba(255,255,255,.08); }
  .atlas-btn:active, .atlas-chip:active, .atlas-export:active { transform: translateY(1px); }
  .atlas-btn.active { background: var(--atlas-accent); color: #1d1608; font-weight: 700; }
  .atlas-search { position: relative; min-width: 0; }
  .atlas-search input {
    width: 100%; box-sizing: border-box; font: inherit; color: var(--atlas-text);
    background: rgba(255,255,255,.045); border: 1px solid var(--atlas-line);
    border-radius: 999px; padding: .42rem .75rem .42rem 2rem; outline: none;
  }
  .atlas-search input:focus { border-color: rgba(242,193,95,.65); box-shadow: 0 0 0 3px rgba(242,193,95,.12); }
  .atlas-search:before { content: "search"; position: absolute; left: .7rem; top: 50%; transform: translateY(-50%); color: var(--atlas-faint); font-size: .63rem; letter-spacing: .08em; text-transform: uppercase; pointer-events: none; }
  .atlas-status { justify-self: end; color: var(--atlas-muted); font-variant-numeric: tabular-nums; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; }
  .atlas-stage { position: relative; flex: 1 1 0; min-width: 0; min-height: 34rem; background: rgba(2, 8, 18, .34); }
  .atlas-graph { position: absolute; inset: 0; }
  .atlas-veil {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: radial-gradient(circle at center, rgba(12,23,38,.82), rgba(8,17,29,.96));
    color: var(--atlas-muted); font-size: .9rem; z-index: 4; font-variant-numeric: tabular-nums;
  }
  .atlas-empty { padding: 3rem 1rem; text-align: center; color: var(--atlas-muted); }
  .atlas-cats { display: flex; gap: .35rem; flex-wrap: wrap; padding: .56rem .72rem; border-top: 1px solid var(--atlas-line); background: rgba(8,17,29,.76); }
  .atlas-chip { color: var(--atlas-muted); border-color: var(--atlas-line); padding: .22rem .52rem; font-size: .76rem; }
  .atlas-chip.active { color: var(--atlas-text); background: rgba(255,255,255,.07); }
  .atlas-chip[data-category="context"] { opacity: .72; }
  .atlas-side { display: none; border-top: 1px solid var(--atlas-line); background: rgba(8,17,29,.92); max-height: 44dvh; overflow: auto; }
  .atlas-wrap.inspector-open .atlas-side { display: block; }
  .atlas-side-head { padding: .82rem .9rem; border-bottom: 1px solid var(--atlas-line); }
  .atlas-side-top { display: flex; align-items: center; justify-content: space-between; gap: .75rem; }
  .atlas-side-kicker { color: var(--atlas-accent); text-transform: uppercase; letter-spacing: .11em; font-size: .66rem; font-weight: 800; }
  .atlas-side-title { margin-top: .28rem; font-weight: 750; color: #f4f7fb; }
  .atlas-side-close { border: 1px solid var(--atlas-line); background: rgba(255,255,255,.045); color: var(--atlas-muted); border-radius: 999px; font: inherit; font-size: .74rem; padding: .18rem .48rem; cursor: pointer; }
  .atlas-side-close:hover { color: var(--atlas-text); background: rgba(255,255,255,.075); }
  .atlas-inspector { padding: .9rem; overflow: auto; font-size: .82rem; line-height: 1.45; }
  .atlas-inspector h3 { margin: 0 0 .32rem; font-size: 1rem; line-height: 1.2; color: #f4f7fb; text-wrap: balance; }
  .atlas-inspector .muted { color: var(--atlas-muted); }
  .atlas-kv { display: grid; grid-template-columns: 6.8rem minmax(0,1fr); gap: .28rem .55rem; margin-top: .8rem; }
  .atlas-kv dt { color: var(--atlas-faint); }
  .atlas-kv dd { margin: 0; color: var(--atlas-text); min-width: 0; overflow-wrap: anywhere; }
  .atlas-open { display: inline-flex; margin-top: .9rem; color: #1d1608; background: var(--atlas-accent); border-radius: 999px; padding: .36rem .7rem; text-decoration: none; font-weight: 750; }
  .atlas-gaps { margin-top: 1rem; padding-top: .7rem; border-top: 1px dashed rgba(240,127,120,.35); }
  .atlas-gaps .gap { color: var(--atlas-danger); }
  .atlas-warn { display: none; padding: .45rem .72rem; background: rgba(242,193,95,.10); color: #ffd88a; font-size: .78rem; border-top: 1px solid rgba(242,193,95,.18); }
  .atlas-export { justify-self: start; border-color: var(--atlas-line); color: var(--atlas-muted); text-decoration: none; }
  .atlas-export code { color: var(--atlas-text); font-size: .72rem; }
  @media (max-width: 980px) {
    .atlas-split, .atlas-shell.swapped .atlas-split { flex-direction: column; }
    .atlas-neighbors, .atlas-shell.swapped .atlas-neighbors { flex: 0 0 auto; max-height: 40dvh; border-left: 0; border-right: 0; border-top: 1px solid var(--atlas-line); }
    .atlas-bar { grid-template-columns: 1fr; align-items: stretch; }
    .atlas-status { justify-self: start; }
    .atlas-stage { min-height: 52dvh; }
  }
</style>

<div class="atlas-wrap" data-atlas-root>
  <div class="atlas-shell" data-atlas-shell>
    <section class="atlas-main" aria-label="Atlas graph workspace">
      <div class="atlas-bar">
        <div class="atlas-mode" aria-label="Atlas lens">
          <button class="atlas-btn active" type="button" data-atlas-lens="overview">Overview</button>
          <button class="atlas-btn" type="button" data-atlas-lens="ego">Ego</button>
        </div>
        <label class="atlas-search">
          <input type="search" data-atlas-search placeholder="Find a record, subject, agency, or cited work" autocomplete="off">
        </label>
        <button class="atlas-btn" type="button" data-atlas-reset>Reset camera</button>
        <button class="atlas-btn" type="button" data-atlas-swap title="Swap the graph and list sides">Swap sides</button>
        <button class="atlas-btn" type="button" data-atlas-inspector-toggle aria-expanded="false">Inspector</button>
        <span class="atlas-export" title="Standalone export is generated by the Rails task"><code>rake enliterator:atlas FILE=tmp/atlas.html</code></span>
        <span class="atlas-status" data-atlas-status>loading atlas shell</span>
      </div>
      <div class="atlas-controls" data-atlas-controls hidden aria-label="Ego lens filters"></div>
      <div class="atlas-split" data-atlas-split>
        <div class="atlas-stage" data-atlas-stage>
          <div class="atlas-graph" data-atlas-graph></div>
          <div class="atlas-veil" data-atlas-veil>loading the atlas data...</div>
        </div>
        <div class="atlas-neighbors" data-atlas-neighbors hidden aria-label="Ranked neighbors">
          <div class="atlas-neighbors-head">
            <span class="atlas-side-kicker">Neighbors</span>
            <select class="atlas-neighbors-sort" data-atlas-neighbors-sort aria-label="Sort neighbors">
              <option value="relation">by relation</option>
              <option value="degree">by degree</option>
              <option value="recency">by recency</option>
            </select>
          </div>
          <div class="atlas-neighbors-list" data-atlas-neighbors-list>
            <p class="atlas-neighbors-empty">Center the Ego lens on a record or entity to see its ranked neighbors.</p>
          </div>
        </div>
      </div>
      <div class="atlas-cats" data-atlas-categories aria-label="Edge categories"></div>
      <div class="atlas-warn" data-atlas-warn></div>
      <aside class="atlas-side" aria-label="Atlas selection inspector">
        <div class="atlas-side-head">
          <div class="atlas-side-top">
            <div class="atlas-side-kicker">Selection</div>
            <button class="atlas-side-close" type="button" data-atlas-inspector-close>Close</button>
          </div>
          <div class="atlas-side-title" data-atlas-side-title>Nothing selected</div>
        </div>
        <div class="atlas-inspector" data-atlas-inspector>
          <p class="muted">Select a node or edge to inspect its claims, provenance, and known gaps. The Overview lens labels only context hubs and the most useful bridge points; switch to the Ego lens (or search) to center on a known record or term and explore its neighborhood.</p>
        </div>
      </aside>
    </section>
  </div>
</div>

<script>
  window.ATLAS_DATA = <%= atlas ? raw(ERB::Util.json_escape(atlas.to_json)) : "null" %>;
  window.ATLAS_DATA_URL = <%= local_assigns[:data_url] ? raw(ERB::Util.json_escape(local_assigns[:data_url].to_json)) : "null" %>;
  window.ATLAS_EMBEDDED = <%= embedded ? "true" : "false" %>;
</script>
<script>
<%= raw Enliterator::Atlas.renderer_bundle %>
</script>
<script>
window.EnliteratorAtlas = (function () {
  "use strict";

  const EDGE_CATEGORIES = ["context", "citation", "authority", "agent", "subject", "evidence", "other"];
  // Stage 1: the surface speaks "lenses"; the server still speaks "modes". The
  // Overview lens reads the overview mode; the Ego lens reads the focus mode.
  const LENS_TO_MODE = { overview: "overview", ego: "focus" };
  const MODE_TO_LENS = { overview: "overview", focus: "ego", explore: "overview" };
  const CONTEXT_PALETTE = ["#53d6ba", "#6da8ff", "#f2c15f", "#ef7c8e", "#b99cff", "#7bdff2", "#f7a66a", "#8be28d"];
  const ENTITY_COLOR = "#9aa8ba";
  const SELECT_COLOR = "#f2c15f";
  const EDGE_NEUTRAL = "rgba(125, 145, 170, .18)";

  function escapeHtml(value) {
    return String(value == null ? "" : value).replace(/[&<>'"]/g, function (ch) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", "'": "&#39;", '"': "&quot;" }[ch];
    });
  }

  function edgeId(edge, idx) {
    return edge.id || ["edge", idx, edge.s, edge.t, edge.key].join(":");
  }

  function nodeSize(node) {
    if (node.kind === "context") return 15 + Math.min(Math.sqrt(node.size || 1) * 0.12, 2);
    if (node.kind === "record") return 4 + Math.min(Math.sqrt(node.size || 1) * 1.35, 8);
    return 3 + Math.min(Math.sqrt(node.degree || node.size || 1) * 1.15, 7);
  }

  function truncatedLabel(data) {
    const raw = String(data.label || "");
    const limit = data.kind === "context" ? 34 : 30;
    return raw.length > limit ? raw.slice(0, limit - 1) + "…" : raw;
  }

  function drawAtlasNodeLabel(context, data, settings) {
    if (!data.label) return;
    const size = data.kind === "context" ? 13 : 12;
    const text = truncatedLabel(data);
    const x = data.x + data.size + 5;
    const y = data.y + size / 3;
    context.save();
    context.font = (data.kind === "context" ? "800 " : "700 ") + size + "px " + settings.labelFont;
    context.lineJoin = "round";
    context.strokeStyle = "rgba(8,17,29,.94)";
    context.lineWidth = data.kind === "context" ? 5 : 4;
    context.strokeText(text, x, y);
    context.fillStyle = data.kind === "context" ? "#f6f8fb" : "#dce5ef";
    context.fillText(text, x, y);
    context.restore();
  }

  function drawAtlasNodeHover(context, data, settings) {
    context.save();
    context.strokeStyle = SELECT_COLOR;
    context.lineWidth = data.kind === "context" ? 2.4 : 2;
    context.beginPath();
    context.arc(data.x, data.y, data.size + 3, 0, Math.PI * 2);
    context.stroke();
    context.restore();
    drawAtlasNodeLabel(context, data, settings);
  }

  function buildContextColors(nodes) {
    const groups = Array.from(new Set(nodes.filter(n => n.kind === "record" || n.kind === "context").map(n => n.group || n.id))).sort();
    const colors = new Map();
    groups.forEach((group, idx) => colors.set(group, CONTEXT_PALETTE[idx % CONTEXT_PALETTE.length]));
    return colors;
  }

  function nodeColor(node, contextColors) {
    if (node.kind === "context") return contextColors.get(node.group || node.id) || SELECT_COLOR;
    if (node.kind === "record") return contextColors.get(node.group || "root") || "#53d6ba";
    return ENTITY_COLOR;
  }

  function edgeColor(edge) {
    if (edge.category === "context") return "rgba(135,150,170,.04)";
    return EDGE_NEUTRAL;
  }

  function multiplyAlpha(color, factor) {
    const rgba = String(color || "").match(/^rgba\(([^,]+),([^,]+),([^,]+),([^)]+)\)$/);
    if (!rgba) return color;
    const alpha = Math.max(0, Math.min(1, parseFloat(rgba[4]) * factor));
    return "rgba(" + rgba[1].trim() + "," + rgba[2].trim() + "," + rgba[3].trim() + "," + alpha.toFixed(3) + ")";
  }

  function buildGraphModel(data, vendor) {
    if (!vendor || !vendor.Graph) throw new Error("Atlas renderer bundle did not expose Graphology");
    const graph = new vendor.Graph({ multi: true, allowSelfLoops: false });
    const nodes = data.nodes || [];
    const edges = data.edges || [];
    const contextColors = buildContextColors(nodes);
    const rawNodes = new Map();
    const rawEdges = new Map();
    const degree = new Map();

    nodes.forEach(function (node) {
      rawNodes.set(node.id, node);
      graph.addNode(node.id, {
        label: node.label || node.id,
        x: Number.isFinite(node.x) ? node.x : 0,
        y: Number.isFinite(node.y) ? node.y : 0,
        size: nodeSize(node),
        color: nodeColor(node, contextColors),
        kind: node.kind,
        group: node.group,
        path: node.path,
        degree: node.degree || 0,
        labelPriority: node.label_priority || 0,
        raw: node
      });
    });

    edges.forEach(function (edge, idx) {
      if (!rawNodes.has(edge.s) || !rawNodes.has(edge.t)) return;
      const id = edgeId(edge, idx);
      rawEdges.set(id, edge);
      degree.set(edge.s, (degree.get(edge.s) || 0) + 1);
      degree.set(edge.t, (degree.get(edge.t) || 0) + 1);
      graph.addEdgeWithKey(id, edge.s, edge.t, {
        label: edge.key,
        size: edge.category === "context" ? 0.25 : 0.75 + Math.min(edge.w || 0.5, 1) * 1.15,
        color: edgeColor(edge),
        category: edge.category || "other",
        keyName: edge.key,
        raw: edge
      });
    });

    return { graph, rawNodes, rawEdges, degree, contextColors };
  }

  function runHiddenLayout(graph, vendor, mode, notice) {
    if (!vendor.forceAtlas2 || graph.order < 2) return;
    const iterations = mode === "overview" ? 170 : (graph.order > 900 ? 70 : 115);
    try {
      const inferred = vendor.forceAtlas2.inferSettings ? vendor.forceAtlas2.inferSettings(graph) : {};
      vendor.forceAtlas2.assign(graph, {
        iterations: iterations,
        settings: Object.assign({}, inferred, {
          gravity: mode === "overview" ? 1.2 : 0.8,
          scalingRatio: mode === "overview" ? 22 : 16,
          slowDown: 1.8,
          barnesHutOptimize: graph.order > 350
        })
      });
    } catch (error) {
      console.warn("Atlas layout fallback; using deterministic seed positions", error);
      if (notice) notice("Layout fallback: deterministic seed positions are shown.");
    }
  }

  function modeUrl(dataUrl, mode, focus) {
    const url = new URL(dataUrl, window.location.href);
    url.searchParams.set("mode", mode);
    if (focus) url.searchParams.set("focus", focus);
    else url.searchParams.delete("focus");
    return url.pathname + url.search;
  }

  function chooseSearchMatch(nodes, query) {
    const q = String(query || "").trim().toLowerCase();
    if (!q) return null;
    const exact = nodes.find(n => String(n.label || "").toLowerCase() === q || String(n.id).toLowerCase() === q);
    if (exact) return exact;
    return nodes
      .filter(n => String(n.label || "").toLowerCase().includes(q) || String(n.id).toLowerCase().includes(q))
      .sort((a, b) => (b.label_priority || 0) - (a.label_priority || 0) || (b.degree || 0) - (a.degree || 0))[0] || null;
  }

  // Stage 1: the ranked neighbor list — projected client-side from the focus
  // payload (no new endpoint). Each edge touching the center yields one row,
  // labelled with the relation (the vocabulary key) and the neighbor's strength.
  // Sorts: relation (grouped), degree (hubs first), recency (newest claims first).
  function rankedNeighbors(data, centerId, sort) {
    sort = sort || "relation";
    const byId = new Map((data.nodes || []).map(function (n) { return [n.id, n]; }));
    const rows = [];
    (data.edges || []).forEach(function (e) {
      let otherId = null;
      if (e.s === centerId) otherId = e.t;
      else if (e.t === centerId) otherId = e.s;
      if (!otherId) return;
      const n = byId.get(otherId) || { id: otherId, label: otherId, kind: "entity" };
      rows.push({
        id: otherId, label: n.label || otherId, kind: n.kind,
        relation: e.key, category: e.category || "other",
        confidence: e.w != null ? Number(e.w) : null,
        degree: n.degree || 0, at: e.at || 0
      });
    });
    if (sort === "degree") {
      rows.sort(function (a, b) { return (b.degree || 0) - (a.degree || 0) || (b.confidence || 0) - (a.confidence || 0); });
    } else if (sort === "recency") {
      rows.sort(function (a, b) { return (b.at || 0) - (a.at || 0) || (b.confidence || 0) - (a.confidence || 0); });
    } else {
      rows.sort(function (a, b) { return String(a.relation).localeCompare(String(b.relation)) || (b.confidence || 0) - (a.confidence || 0); });
    }
    return rows;
  }

  function topEdgeTypes(nodeId, edges) {
    const counts = new Map();
    edges.forEach(function (edge) {
      if (edge.s !== nodeId && edge.t !== nodeId) return;
      counts.set(edge.key, (counts.get(edge.key) || 0) + 1);
    });
    return Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0])).slice(0, 6);
  }

  function recordUrl(node, embedded) {
    if (embedded || !node.path) return null;
    const base = window.location.pathname.replace(/\/atlas\/?$/, "");
    return base + "/" + node.path;
  }

  function inspectorForNode(node, data, embedded) {
    const edgeTypes = topEdgeTypes(node.id, data.edges || []);
    const open = recordUrl(node, embedded);
    return '' +
      '<h3>' + escapeHtml(node.label || node.id) + '</h3>' +
      '<p class="muted">' + escapeHtml(node.kind || "node") + (node.group ? ' · ' + escapeHtml(node.group) : '') + '</p>' +
      '<dl class="atlas-kv">' +
        '<dt>id</dt><dd><code>' + escapeHtml(node.id) + '</code></dd>' +
        '<dt>degree</dt><dd>' + escapeHtml(node.degree || 0) + '</dd>' +
        '<dt>size</dt><dd>' + escapeHtml(node.size || 0) + '</dd>' +
        '<dt>labels</dt><dd>' + (node.label_priority ? 'priority ' + escapeHtml(node.label_priority) : 'on hover/search/selection') + '</dd>' +
        '<dt>edge types</dt><dd>' + (edgeTypes.length ? edgeTypes.map(pair => '<code>' + escapeHtml(pair[0]) + '</code> ' + pair[1]).join('<br>') : 'none in this view') + '</dd>' +
      '</dl>' +
      (open ? '<a class="atlas-open" href="' + escapeHtml(open) + '">Open record</a>' : '');
  }

  function inspectorForEdge(edge, model) {
    const source = model.rawNodes.get(edge.s) || { label: edge.s };
    const target = model.rawNodes.get(edge.t) || { label: edge.t };
    const asserted = edge.at ? new Date(edge.at * 1000).toISOString().slice(0, 10) : "unknown";
    return '' +
      '<h3><code>' + escapeHtml(edge.key || "edge") + '</code></h3>' +
      '<p class="muted">' + escapeHtml(source.label) + ' -> ' + escapeHtml(target.label) + '</p>' +
      '<dl class="atlas-kv">' +
        '<dt>category</dt><dd>' + escapeHtml(edge.category || "other") + '</dd>' +
        '<dt>asserted</dt><dd>' + escapeHtml(asserted) + '</dd>' +
        '<dt>tier</dt><dd>' + escapeHtml(edge.tier || "unknown") + '</dd>' +
        '<dt>confidence</dt><dd>' + escapeHtml(edge.w != null ? Number(edge.w).toFixed(2) : "unknown") + '</dd>' +
        '<dt>audit</dt><dd>' + escapeHtml(edge.verdict || "not audited") + '</dd>' +
      '</dl>';
  }

  // "r:Type:id" — the id is the last colon-segment (integer or uuid, neither
  // contains a colon); the type is everything between. Robust to "::" in a type.
  function parseRecordId(nodeId) {
    const body = String(nodeId || "").slice(2);
    const idx = body.lastIndexOf(":");
    if (idx < 0) return null;
    return { type: body.slice(0, idx), id: body.slice(idx + 1) };
  }

  function relRecordPath(path) {
    if (!path) return "#";
    const base = window.location.pathname.replace(/\/atlas\/?$/, "");
    return base + "/" + path;
  }

  // Stage 1: the record inspector — the selected node's live claims with
  // provenance (tier · confidence · date · audit verdict) AND its known gaps
  // (lacunae), because the gap is part of the record's truth. Everything is
  // escaped through escapeHtml — tool/claim data is never trusted as markup.
  function inspectorForRecord(payload, embedded) {
    const node = payload.node || {};
    const claims = payload.claims || [];
    const gaps = payload.lacunae || [];
    const open = (!embedded && node.path) ? ('<a class="atlas-open" href="' + escapeHtml(relRecordPath(node.path)) + '">Open record</a>') : '';
    const claimRows = claims.map(function (c) {
      const at = c.asserted_at ? new Date(c.asserted_at * 1000).toISOString().slice(0, 10) : "";
      return '<dt>' + escapeHtml(c.key) + '</dt><dd>' +
        escapeHtml(String(c.value == null ? "" : c.value)).slice(0, 240) +
        ' <span class="muted">· ' + escapeHtml(c.tier || "") + ' · ' +
        escapeHtml(c.confidence != null ? Number(c.confidence).toFixed(2) : "") +
        (at ? ' · ' + escapeHtml(at) : '') +
        (c.verdict ? ' · ' + escapeHtml(c.verdict) : '') + '</span></dd>';
    }).join('');
    const claimBlock = claimRows ? ('<dl class="atlas-kv">' + claimRows + '</dl>') : '<p class="muted">No claims recorded for this record yet.</p>';
    const gapBlock = gaps.length ? ('<div class="atlas-gaps"><div class="atlas-side-kicker">Known gaps</div><dl class="atlas-kv">' +
      gaps.map(function (g) {
        return '<dt class="gap">' + escapeHtml(g.key) + '</dt><dd class="gap">' +
          escapeHtml(g.diagnosis || "undiagnosed") + (g.note ? ' — ' + escapeHtml(g.note) : '') + '</dd>';
      }).join('') + '</dl></div>') : '';
    return '<h3>' + escapeHtml(node.label || "") + '</h3>' + claimBlock + gapBlock + open;
  }

  function createApp(options) {
    const root = options.root;
    const embedded = !!options.embedded;
    const dataUrl = options.dataUrl;
    const vendor = options.rendererVendor || window.EnliteratorAtlasRenderer;
    const fetchImpl = options.fetch || window.fetch;
    const els = {
      shell: root.querySelector("[data-atlas-shell]"),
      graph: root.querySelector("[data-atlas-graph]"),
      veil: root.querySelector("[data-atlas-veil]"),
      status: root.querySelector("[data-atlas-status]"),
      warn: root.querySelector("[data-atlas-warn]"),
      categories: root.querySelector("[data-atlas-categories]"),
      controls: root.querySelector("[data-atlas-controls]"),
      neighbors: root.querySelector("[data-atlas-neighbors]"),
      neighborsList: root.querySelector("[data-atlas-neighbors-list]"),
      neighborsSort: root.querySelector("[data-atlas-neighbors-sort]"),
      inspector: root.querySelector("[data-atlas-inspector]"),
      sideTitle: root.querySelector("[data-atlas-side-title]"),
      search: root.querySelector("[data-atlas-search]"),
      reset: root.querySelector("[data-atlas-reset]"),
      swap: root.querySelector("[data-atlas-swap]"),
      inspectorToggle: root.querySelector("[data-atlas-inspector-toggle]"),
      inspectorClose: root.querySelector("[data-atlas-inspector-close]"),
      lensButtons: Array.from(root.querySelectorAll("[data-atlas-lens]"))
    };
    const state = {
      data: null,
      model: null,
      renderer: null,
      mode: "overview",
      selectedNode: null,
      hoveredNode: null,
      selectedEdge: null,
      hoveredEdge: null,
      query: "",
      activeCategories: new Set(EDGE_CATEGORIES),
      filters: {},
      neighborSort: "relation"
    };

    function setStatus(text) { els.status.textContent = text; }
    function setWarning(text) {
      if (!text) { els.warn.style.display = "none"; els.warn.textContent = ""; return; }
      els.warn.style.display = "block";
      els.warn.textContent = text;
    }
    function setActiveMode(mode) {
      state.mode = mode;
      const lens = MODE_TO_LENS[mode] || "overview";
      els.lensButtons.forEach(function (btn) { btn.classList.toggle("active", btn.dataset.atlasLens === lens); });
      applyLensChrome(lens);
    }
    // The Ego-only chrome (ranked-neighbor pane + filter controls) is shown only
    // when the Ego lens is active; the Overview lens is the full-width graph.
    function applyLensChrome(lens) {
      const ego = lens === "ego";
      if (els.neighbors) els.neighbors.hidden = !ego;
      if (els.controls) els.controls.hidden = !ego;
    }
    function readPref(key) {
      try { return window.localStorage ? window.localStorage.getItem(key) : null; } catch (e) { return null; }
    }
    function writePref(key, value) {
      try { if (window.localStorage) window.localStorage.setItem(key, value); } catch (e) { /* private mode */ }
    }
    // Side preference: graph-left for first-time visitors (an onboarding read);
    // a swap is remembered per browser so power users keep the list (text) left.
    function applySwapPreference() {
      if (els.shell) els.shell.classList.toggle("swapped", readPref("enl-atlas-side") === "list-left");
    }
    function toggleSwap() {
      if (!els.shell) return;
      const swapped = els.shell.classList.toggle("swapped");
      writePref("enl-atlas-side", swapped ? "list-left" : "graph-left");
      if (state.renderer && state.renderer.refresh) window.setTimeout(function () { state.renderer.refresh(); }, 90);
    }
    function setInspectorOpen(open) {
      root.classList.toggle("inspector-open", open);
      if (els.inspectorToggle) {
        els.inspectorToggle.setAttribute("aria-expanded", open ? "true" : "false");
        els.inspectorToggle.textContent = open ? "Hide inspector" : "Inspector";
      }
      if (state.renderer && state.renderer.refresh) {
        window.setTimeout(function () { state.renderer.refresh(); }, 80);
      }
    }
    function connectedNodeIds(nodeId) {
      const ids = new Set([nodeId]);
      if (!state.data) return ids;
      state.data.edges.forEach(function (edge) {
        if (edge.s === nodeId) ids.add(edge.t);
        if (edge.t === nodeId) ids.add(edge.s);
      });
      return ids;
    }
    function refresh() { if (state.renderer) state.renderer.refresh(); }

    function updateInspectorNode(nodeId) {
      const node = state.model.rawNodes.get(nodeId);
      if (!node) return;
      els.sideTitle.textContent = node.kind === "record" ? "Record" : node.kind === "context" ? "Context" : "Bridge term";
      els.inspector.innerHTML = inspectorForNode(node, state.data, embedded);
    }
    function updateInspectorEdge(edgeId) {
      const edge = state.model.rawEdges.get(edgeId);
      if (!edge) return;
      els.sideTitle.textContent = "Claim edge";
      els.inspector.innerHTML = inspectorForEdge(edge, state.model);
    }
    function selectNode(nodeId) {
      state.selectedNode = nodeId;
      state.selectedEdge = null;
      highlightNeighbor(nodeId);
      setInspectorOpen(true);
      if (String(nodeId).indexOf("r:") === 0) loadRecordInspector(nodeId);
      else updateInspectorNode(nodeId);
      refresh();
    }

    // Record nodes get the full inspector (claims + provenance + lacunae) from
    // /atlas/node; the edge-derived summary renders immediately while it loads.
    // Entity/context nodes keep the edge-derived inspector (no record behind them).
    function loadRecordInspector(nodeId) {
      const node = state.model && state.model.rawNodes.get(nodeId);
      els.sideTitle.textContent = "Record";
      if (node) els.inspector.innerHTML = inspectorForNode(node, state.data, embedded);
      const parsed = parseRecordId(nodeId);
      if (!parsed || embedded || !dataUrl) return;
      fetchImpl(recordInspectUrl(parsed.type, parsed.id), { headers: { "Accept": "application/json" } })
        .then(function (response) { if (!response.ok) throw new Error("inspect HTTP " + response.status); return response.json(); })
        .then(function (payload) {
          if (state.selectedNode !== nodeId) return;   // selection moved on; drop the stale render
          els.inspector.innerHTML = inspectorForRecord(payload, embedded);
        })
        .catch(function (error) { console.warn("Atlas inspect request failed", error); });
    }
    function recordInspectUrl(type, id) {
      const u = new URL(dataUrl, window.location.href);
      u.pathname = u.pathname.replace(/\/data$/, "/node");
      const ctx = u.searchParams.get("context");
      u.search = "";
      u.searchParams.set("type", type);
      u.searchParams.set("id", id);
      if (ctx) u.searchParams.set("context", ctx);
      return u.pathname + u.search;
    }
    function selectEdge(edgeId) {
      state.selectedEdge = edgeId;
      state.selectedNode = null;
      updateInspectorEdge(edgeId);
      setInspectorOpen(true);
      refresh();
    }
    function resetCamera() {
      if (!state.renderer) return;
      const camera = state.renderer.getCamera && state.renderer.getCamera();
      if (camera && camera.animatedReset) camera.animatedReset({ duration: 360 });
      else if (camera && camera.setState) camera.setState({ x: 0.5, y: 0.5, ratio: 1 });
    }
    function centerNode(nodeId) {
      if (!state.renderer || !state.model.graph.hasNode(nodeId)) return;
      const camera = state.renderer.getCamera && state.renderer.getCamera();
      const attrs = state.model.graph.getNodeAttributes(nodeId);
      if (camera && camera.animate) camera.animate({ x: attrs.x, y: attrs.y, ratio: Math.min((camera.ratio || 1) * 0.72, 1) }, { duration: 320 });
    }
    function applySearch(query) {
      state.query = String(query || "").trim().toLowerCase();
      if (state.query.length >= 2 && state.data) {
        const match = chooseSearchMatch(state.data.nodes, state.query);
        if (match) { selectNode(match.id); centerNode(match.id); }
      }
      refresh();
    }
    function categoryToggles() {
      els.categories.innerHTML = "";
      EDGE_CATEGORIES.forEach(function (category) {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "atlas-chip active";
        button.dataset.category = category;
        button.textContent = category;
        button.addEventListener("click", function () {
          if (state.activeCategories.has(category)) state.activeCategories.delete(category);
          else state.activeCategories.add(category);
          button.classList.toggle("active", state.activeCategories.has(category));
          refresh();
        });
        els.categories.appendChild(button);
      });
    }

    // The Ego lens's ranked neighbor list — the center is the server-echoed
    // focus (meta.focus), so the list and graph share one selection. Rows are
    // clickable → selectNode, which both the graph and the inspector follow.
    function renderNeighbors() {
      if (!els.neighborsList) return;
      const center = (state.data && state.data.meta && state.data.meta.focus) || state.selectedNode;
      if (!state.data || !center) {
        els.neighborsList.innerHTML = '<p class="atlas-neighbors-empty">Center the Ego lens on a record or entity to see its ranked neighbors.</p>';
        return;
      }
      const rows = rankedNeighbors(state.data, center, state.neighborSort);
      if (!rows.length) {
        els.neighborsList.innerHTML = '<p class="atlas-neighbors-empty">No neighbors in this view. Loosen the filters or raise the depth.</p>';
        return;
      }
      const grouped = state.neighborSort === "relation";
      let html = "", lastRel = null;
      rows.forEach(function (row) {
        if (grouped && row.relation !== lastRel) {
          html += '<div class="atlas-ngrp">' + escapeHtml(row.relation) + '</div>';
          lastRel = row.relation;
        }
        const conf = row.confidence != null ? Number(row.confidence).toFixed(2) : "";
        html += '<button type="button" class="atlas-nrow" data-neighbor="' + escapeHtml(row.id) + '">' +
                '<span class="nlabel">' + escapeHtml(row.label) + '</span>' +
                '<span class="nconf">' + escapeHtml(conf) + '</span></button>';
      });
      els.neighborsList.innerHTML = html;
      Array.prototype.forEach.call(els.neighborsList.querySelectorAll("[data-neighbor]"), function (btn) {
        btn.addEventListener("click", function () { selectNode(btn.dataset.neighbor); });
      });
      highlightNeighbor(state.selectedNode);
    }
    function highlightNeighbor(id) {
      if (!els.neighborsList) return;
      Array.prototype.forEach.call(els.neighborsList.querySelectorAll("[data-neighbor]"), function (btn) {
        btn.classList.toggle("active", btn.dataset.neighbor === id);
      });
    }

    function renderData(data) {
      if (state.renderer && state.renderer.kill) state.renderer.kill();
      els.graph.innerHTML = "";
      state.data = data || { nodes: [], edges: [], meta: {} };
      state.selectedNode = null;
      state.selectedEdge = null;
      state.hoveredNode = null;
      state.hoveredEdge = null;
      setActiveMode((state.data.meta && state.data.meta.mode) || state.mode || "overview");
      setWarning((state.data.meta && state.data.meta.warnings || []).join(" "));
      renderNeighbors();

      if (!state.data.nodes || state.data.nodes.length === 0) {
        els.veil.style.display = "none";
        els.graph.innerHTML = '<div class="atlas-empty">Nothing tended yet. The atlas draws itself as the heartbeat reads the collection.</div>';
        setStatus("0 nodes");
        return;
      }

      els.veil.style.display = "flex";
      els.veil.textContent = "laying out " + state.data.nodes.length + " nodes";
      state.model = buildGraphModel(state.data, vendor);
      runHiddenLayout(state.model.graph, vendor, state.mode, setWarning);

      state.renderer = new vendor.Sigma(state.model.graph, els.graph, {
        allowInvalidContainer: true,
        hideEdgesOnMove: true,
        renderEdgeLabels: false,
        enableEdgeEvents: true,
        minEdgeThickness: 0.55,
        labelFont: "Avenir Next, ui-sans-serif, system-ui, sans-serif",
        labelWeight: "650",
        labelColor: { color: "#d7e0eb" },
        labelRenderedSizeThreshold: state.mode === "overview" ? 8 : 12,
        defaultEdgeColor: EDGE_NEUTRAL,
        defaultDrawNodeLabel: drawAtlasNodeLabel,
        defaultDrawNodeHover: drawAtlasNodeHover,
        nodeReducer: function (nodeId, attrs) {
          const raw = attrs.raw || {};
          const selected = state.selectedNode === nodeId || state.hoveredNode === nodeId;
          const neighborhood = state.selectedNode ? connectedNodeIds(state.selectedNode) : null;
          const matched = state.query && String(attrs.label || "").toLowerCase().includes(state.query);
          const dim = (neighborhood && !neighborhood.has(nodeId)) || (state.query && !matched);
          const mustLabel = raw.kind === "context" || selected || matched;
          return Object.assign({}, attrs, {
            label: mustLabel ? attrs.label : "",
            color: selected ? SELECT_COLOR : attrs.color,
            size: selected ? attrs.size + 3 : attrs.size,
            zIndex: selected ? 20 : raw.kind === "context" ? 12 : raw.kind === "record" ? 8 : 4,
            forceLabel: selected || matched || raw.kind === "context",
            hidden: false,
            highlighted: selected,
            colorOpacity: dim ? .22 : 1
          });
        },
        edgeReducer: function (edgeId, attrs) {
          const raw = attrs.raw || {};
          const category = attrs.category || "other";
          const active = state.activeCategories.has(category);
          const selected = state.selectedEdge === edgeId;
          const nodePath = state.selectedNode && (raw.s === state.selectedNode || raw.t === state.selectedNode);
          const dimUnconnected = state.selectedNode && !nodePath && !selected;
          const mutedContext = category === "context" && state.mode === "overview" && !nodePath && !selected;
          return Object.assign({}, attrs, {
            hidden: !active || mutedContext,
            color: selected || nodePath ? SELECT_COLOR : mutedContext ? "rgba(135,150,170,.06)" : dimUnconnected ? multiplyAlpha(attrs.color, 0.5) : attrs.color,
            size: selected || nodePath ? Math.max(attrs.size, 2.4) : mutedContext ? .15 : dimUnconnected ? Math.max(attrs.size * 0.5, 0.55) : attrs.size,
            zIndex: selected || nodePath ? 12 : 1
          });
        }
      });

      state.renderer.on("enterNode", function (event) { state.hoveredNode = event.node; refresh(); });
      state.renderer.on("leaveNode", function () { state.hoveredNode = null; refresh(); });
      state.renderer.on("clickNode", function (event) { selectNode(event.node); });
      state.renderer.on("clickStage", function () { state.selectedNode = null; state.selectedEdge = null; refresh(); });
      state.renderer.on("enterEdge", function (event) { state.hoveredEdge = event.edge; refresh(); });
      state.renderer.on("leaveEdge", function () { state.hoveredEdge = null; refresh(); });
      state.renderer.on("clickEdge", function (event) { selectEdge(event.edge); });

      els.veil.style.display = "none";
      setStatus(state.data.nodes.length + " nodes · " + state.data.edges.length + " edges · " + state.mode);
      resetCamera();
    }

    async function fetchMode(mode, focus) {
      if (embedded || !dataUrl) {
        setStatus("embedded snapshot: mode data is fixed");
        return;
      }
      setActiveMode(mode);
      els.veil.style.display = "flex";
      els.veil.textContent = "loading " + mode;
      const url = modeUrl(dataUrl, mode, focus);
      const response = await fetchImpl(url, { headers: { "Accept": "application/json" } });
      if (!response.ok) throw new Error("Atlas data request failed: HTTP " + response.status);
      renderData(await response.json());
    }

    function wire() {
      categoryToggles();
      applySwapPreference();
      els.search.addEventListener("input", function (event) { applySearch(event.target.value); });
      els.reset.addEventListener("click", resetCamera);
      if (els.swap) els.swap.addEventListener("click", toggleSwap);
      if (els.neighborsSort) els.neighborsSort.addEventListener("change", function (event) {
        state.neighborSort = event.target.value || "relation";
        renderNeighbors();
      });
      if (els.inspectorToggle) els.inspectorToggle.addEventListener("click", function () {
        setInspectorOpen(!root.classList.contains("inspector-open"));
      });
      if (els.inspectorClose) els.inspectorClose.addEventListener("click", function () {
        setInspectorOpen(false);
      });
      els.lensButtons.forEach(function (button) {
        button.addEventListener("click", function () {
          const lens = button.dataset.atlasLens;
          const nextMode = LENS_TO_MODE[lens] || "overview";
          const focus = nextMode === "focus" ? state.selectedNode : null;
          if (nextMode === "focus" && !focus) {
            setWarning("Select a node (search or click one) before switching to the Ego lens.");
            return;
          }
          fetchMode(nextMode, focus).catch(function (error) {
            console.error(error);
            setWarning(error.message);
            setStatus("load failed");
            els.veil.style.display = "none";
          });
        });
      });
    }

    async function start(initialData) {
      wire();
      if (initialData) { renderData(initialData); return; }
      if (!dataUrl) { renderData({ nodes: [], edges: [], meta: {} }); return; }
      try {
        const response = await fetch(dataUrl, { headers: { "Accept": "application/json" } });
        if (!response.ok) throw new Error("Atlas data request failed: HTTP " + response.status);
        renderData(await response.json());
      } catch (error) {
        console.error(error);
        setWarning(error.message);
        setStatus("load failed");
        els.veil.style.display = "none";
        els.graph.innerHTML = '<div class="atlas-empty">The atlas data could not be loaded. Check the Rails log for the request failure.</div>';
      }
    }

    return { start, renderData, fetchMode, applySearch, selectNode, selectEdge, state };
  }

  function bootFromPage() {
    const root = document.querySelector("[data-atlas-root]");
    if (!root) return;
    document.body.classList.add("enl-atlas-page");
    const app = createApp({ root: root, embedded: window.ATLAS_EMBEDDED, dataUrl: window.ATLAS_DATA_URL });
    window.EnliteratorAtlas.current = app;
    app.start(window.ATLAS_DATA);
  }

  return {
    bootFromPage: bootFromPage,
    createApp: createApp,
    _test: {
      buildGraphModel: buildGraphModel,
      chooseSearchMatch: chooseSearchMatch,
      rankedNeighbors: rankedNeighbors,
      modeUrl: modeUrl,
      inspectorForNode: inspectorForNode,
      inspectorForEdge: inspectorForEdge,
      inspectorForRecord: inspectorForRecord,
      edgeId: edgeId
    }
  };
})();

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", window.EnliteratorAtlas.bootFromPage);
} else {
  window.EnliteratorAtlas.bootFromPage();
}
</script>

<h1>Vocabulary requests</h1>
<p class="muted">
  When a stream's vocabulary can't express something, the model files a request instead of inventing a key.
  The <strong>considerer</strong> reads the whole field, auto-applies the safe verdicts (synonym maps,
  confident rejects), and leaves approvals — which change the contract — for you.
  <strong><%= @pending %></strong> pending · <%= @resolved %> resolved.
</p>

<div style="margin:1rem 0">
  <%= button_to "Consider all requests →", suggestions_consider_path, class: "v-approve",
        data: { turbo: false } %>
  <span class="muted" style="font-size:.85rem">Runs the agent across all <%= @terms.size %> open key<%= "s" if @terms.size != 1 %>.</span>
</div>

<% if @terms.any? %>
  <h2>Pending — <%= @terms.size %> key<%= "s" if @terms.size != 1 %>, by pressure</h2>
  <div class="card">
    <table>
      <tr><th>proposed key</th><th>pressure</th><th>from</th><th>rationale</th><th>considerer</th><th>verdict</th></tr>
      <% @terms.each do |t| %>
        <% key = t.proposed_key %>
        <tr>
          <td>
            <code><%= key %></code>
            <% if t.resurged_count.to_i.positive? %><br><span class="warn" title="re-proposed after a verdict">⚠ resurged <%= t.resurged_count %></span><% end %>
          </td>
          <td><span class="big" style="font-size:1.1rem"><%= t.pressure %></span><br><span class="muted" style="font-size:.75rem"><%= t.distinct_records %> rec</span></td>
          <td class="samples"><%= t.by_stream.keys.join(", ") %></td>
          <td class="samples">
            <%= truncate(t.sample_rationale.to_s, length: 120) %>
            <% if t.sample_example.present? %><br><em><%= truncate(t.sample_example.is_a?(String) ? t.sample_example : t.sample_example.to_json, length: 70) %></em><% end %>
          </td>
          <td class="samples">
            <% if t.recommended_decision.present? %>
              <span class="chip" style="background:var(--accent-soft); color:var(--accent)">
                <%= t.recommended_decision %><%= " → #{t.recommended_map_to}" if t.recommended_map_to.present? %>
                <%= "· #{(t.recommended_confidence.to_f * 100).round}%" if t.recommended_confidence %>
              </span>
              <br><%= truncate(t.recommended_rationale.to_s, length: 90) %>
            <% else %>
              <span class="muted">—</span>
            <% end %>
          </td>
          <td>
            <div class="verdict">
              <%= button_to "Approve", suggestions_verdict_path,
                    params: { proposed_key: key, decision: "approve" }, class: "v-approve" %>
              <%= form_with url: suggestions_verdict_path, method: :post do |f| %>
                <%= f.hidden_field :proposed_key, value: key %>
                <%= f.hidden_field :decision, value: "map" %>
                <%= f.select :mapped_to, @canonical, { selected: t.recommended_map_to, include_blank: "map onto…" } %>
                <%= f.submit "Map" %>
              <% end %>
              <%= button_to "Reject", suggestions_verdict_path,
                    params: { proposed_key: key, decision: "reject" }, class: "v-reject" %>
            </div>
          </td>
        </tr>
      <% end %>
    </table>
  </div>
<% else %>
  <p class="muted">No pending requests — the vocabulary is fully tended.</p>
<% end %>

<% if @reproposed.any? %>
  <h2>Re-proposed after a verdict <span class="muted" style="font-weight:400">— the model is overruling you</span></h2>
  <p class="muted">
    These keys got a verdict, but the model keeps asking for them on later tends. Each re-ask is
    <strong>suppressed</strong> (it doesn't re-flood the queue) and counted here. High counts mean the
    verdict and the data disagree — worth reconsidering.
  </p>
  <div class="card">
    <table>
      <tr><th>proposed key</th><th>your verdict</th><th>times re-asked</th></tr>
      <% @reproposed.each do |t| %>
        <% v = @verdicts[t.proposed_key] %>
        <tr>
          <td><code><%= t.proposed_key %></code></td>
          <td>
            <% if v %>
              <% if v[:status] == "mapped" %>
                <span class="chip">mapped → <code><%= v[:mapped_to] %></code></span>
              <% else %>
                <span class="chip"><%= v[:status] %></span>
              <% end %>
            <% else %>
              <span class="muted">resolved</span>
            <% end %>
          </td>
          <td><span class="big" style="font-size:1.1rem"><%= t.post_verdict_attempts %></span></td>
        </tr>
      <% end %>
    </table>
  </div>
<% end %>

<% if @additions.any? %>
  <h2>Approved &amp; live — codify in your policy</h2>
  <p class="muted">These keys are <strong>already live</strong> in the effective contract — the model emits them as claims now. Paste them into the matching <code>stream</code> in your staffing policy initializer to make them a permanent, versioned code artifact (after which this DB-derived addition is redundant).</p>
  <% @additions.each do |stream, keys| %>
    <div class="card">
      <div class="muted">stream <code><%= stream %></code></div>
<pre class="mono" style="white-space:pre-wrap; margin:.4rem 0 0">keys: {
<% keys.each do |k| -%>
  <%= k %>: "TODO: describe <%= k %>",
<% end -%>
}</pre>
    </div>
  <% end %>
<% end %>

<% if @synonyms.any? %>
  <h2>Mapped (synonyms)</h2>
  <div class="card">
    <table>
      <tr><th>proposed</th><th>→ canonical</th><th>stream</th></tr>
      <% @synonyms.each do |s| %>
        <tr><td><code><%= s[:proposed_key] %></code></td><td><code><%= s[:mapped_to] %></code></td><td class="samples"><%= s[:stream] %></td></tr>
      <% end %>
    </table>
  </div>
<% end %>

<%# Page-specific layout for the pending-request cards. Each proposed term is a
    card: a header line (key + pressure + provenance), then evidence given room
    to breathe (rationale, example, the considerer's verdict), then the action
    group aligned right (Approve · Map · Reject). Components (.card, .chip,
    .badge-live, .btn*, .field, .verdict) come from the layout.
    v0.48: .pulse-* mirror the heartbeat monitor (inline — hard rule 2). %>
<style>
  .pulse-track { height: 10px; background: var(--line); border-radius: 6px; overflow: hidden; margin: .5rem 0 .3rem; }
  .pulse-fill  { height: 100%; width: 0%; background: var(--accent); border-radius: 6px; transition: width .6s ease; }
  .pulse-stats { display: flex; gap: 1.2rem; flex-wrap: wrap; align-items: baseline; }
  .pulse-banner { padding: .5rem .8rem; border-radius: 8px; margin-top: .6rem; font-size: .9rem; display: none; }
  .pulse-banner.warn-bg { background: var(--warn-soft); color: var(--warn); display: block; }
  .request { display: grid; grid-template-columns: 1fr auto; gap: var(--s2) var(--s4); align-items: start; }
  .request .req-head { grid-column: 1 / -1; display: flex; align-items: baseline; flex-wrap: wrap; gap: var(--s2); }
  .request .req-key { font-size: 1.02rem; }
  .request .req-pressure { margin-left: auto; display: flex; align-items: baseline; gap: var(--s2); }
  .request .req-pressure .big { font-size: 1.25rem; line-height: 1; }
  .request .req-evidence { min-width: 0; }
  .request .req-evidence .considerer { margin-top: var(--s3); }
  .request .req-evidence .considerer-rationale { margin-top: var(--s1); }
  .request .req-actions { display: flex; flex-direction: column; gap: var(--s2); align-items: stretch;
    min-width: 12.5rem; }
  .request .req-actions .verdict-map { display: flex; gap: var(--s1); }
  .request .req-actions .verdict-map .field { flex: 1; min-width: 0; }
  .request .req-actions form { display: flex; margin: 0; }
  .request .req-actions form .btn { flex: 1; justify-content: center; }
  /* v0.54: full-evidence + map-target inspectors — progressive disclosure so the default
     card stays scannable but nothing is a dead-end truncation. */
  .request .considerer-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: var(--s2); }
  .request .req-more { margin-top: var(--s2); }
  .request .req-more > summary { cursor: pointer; }
  .request .req-evidence-full .ev-row { padding: var(--s2) 0; border-top: 1px solid var(--line); }
  .request .req-evidence-full .ev-row:first-child { border-top: 0; }
  .request .ev-source { font-size: var(--fs-sm); font-weight: 600; color: var(--accent); margin-bottom: var(--s1); }
  .request .ev-pos { display: inline-block; min-width: 1.6em; padding: 0 .35em; margin-right: .15em;
    background: var(--chip); color: var(--muted); border-radius: var(--r-sm); text-align: center;
    font-variant-numeric: tabular-nums; font-weight: 700; }
  .request .target-info { margin-top: var(--s2); padding-left: var(--s3); border-left: 2px solid var(--line); }
  .request .target-vars { display: flex; flex-wrap: wrap; gap: var(--s1); margin-top: var(--s2); }
  /* v0.53: lead with the considerer's recommended action — reorder it to the top of the
     column (flex order) so the reviewer's eye lands on the one-click accept. Markup order
     is fixed (Approve · Map · Reject); only the recommended lane moves. */
  .request .req-actions.rec-map .act-map { order: -1; }
  .request .req-actions.rec-reject .act-reject { order: -1; }
  @media (max-width: 640px) {
    .request { grid-template-columns: 1fr; }
    .request .req-actions { min-width: 0; }
  }
</style>

<h1>Authority control <span class="subtitle">— the controlled vocabulary, reviewing itself</span></h1>
<p class="muted">
  When the established vocabulary can't express something, the model <em>proposes a term</em> rather than
  inventing one off-list — and a term earns its place by recurring across records (literary warrant). The
  <strong>considerer</strong> reads the whole field, auto-applies the safe verdicts (USE/UF synonym
  references, confident rejects), and leaves the approvals — which change the vocabulary — for you.
  <strong><%= @pending %></strong> pending · <%= @resolved %> resolved.
</p>

<% if @running %>
  <%# ── monitor mode — a considerer run is live; poll it ────────────────── %>
  <div class="card" id="monitor"
       data-pulse-url="<%= suggestions_consider_pulse_path(@running.id) %>"
       data-planned="<%= @running.planned_count.to_i %>">
    <h2 style="margin-top:0">Run #<%= @running.id %> <span class="chip tier">considering</span>
      <span class="subtitle">— started <%= @running.started_at.strftime("%H:%M:%S") %></span></h2>
    <div class="pulse-track"><div class="pulse-fill" id="bar"></div></div>
    <div class="pulse-stats">
      <span><strong id="done-count">0</strong>
        <span class="muted">of <span id="total-count"><%= @running.planned_count.to_i %></span> term(s)</span>
      </span>
      <span class="muted samples" id="phase-label"></span>
    </div>
    <div class="pulse-banner" id="banner"></div>
    <div id="finish"></div>
  </div>
<% else %>
  <div class="strip" style="margin:1rem 0">
    <%= button_to "Consider all requests →", suggestions_consider_path, class: "btn btn-affirmative",
          data: { turbo: false } %>
    <span class="samples">Runs the agent across all <%= @terms.size %> open key<%= "s" if @terms.size != 1 %>.</span>
  </div>
<% end %>

<% if @terms.any? %>
  <h2>Pending — <%= @terms.size %> key<%= "s" if @terms.size != 1 %>, by pressure</h2>
  <%# v0.53: one shared type-ahead source for every card's Map target (the preferred-term
      vocabulary). Rendered once; each Map input references it via list="canonical-terms". %>
  <datalist id="canonical-terms">
    <% @canonical.each do |term| %><option value="<%= term %>"></option><% end %>
  </datalist>
  <% @terms.each do |t| %>
    <% key = t.proposed_key %>
    <%# v0.53: reviewer-flow-first. The card LEADS with the considerer's recommended action
        (primary + green, ordered first via .rec-*), and the map target is ALWAYS pre-selected
        when it's a legal preferred term — so accepting the recommendation is one click.
        rec        = the recommended decision (map/approve/reject or nil).
        rec_target = the map target when rec is map.
        rec_pending= the target isn't yet a preferred term (a pending sibling) → hint, no pre-fill.
        prefill    = the legal pre-filled target (no confidence gate — v0.50's gate removed;
                     confidence is instead surfaced, and marked ⚠ when below the auto-apply floor).
        low_conf   = the recommendation's confidence is below the considerer's auto-apply floor. %>
    <% rec         = t.recommended_decision %>
    <% rec_target  = rec == "map" ? t.recommended_map_to.presence : nil %>
    <% rec_pending = rec_target && !@canonical.include?(rec_target) %>
    <% prefill     = (rec_target if rec_target && @canonical.include?(rec_target)) %>
    <% low_conf    = t.recommended_confidence.present? && t.recommended_confidence.to_f < @min_conf %>
    <div class="card request">
      <div class="req-head">
        <code class="req-key"><%= key %></code>
        <% if t.resurged_count.to_i.positive? %>
          <span class="chip warn" title="re-proposed after a verdict">⚠ resurged <%= t.resurged_count %></span>
        <% end %>
        <span class="samples"><%= t.by_facet.keys.join(", ") %></span>
        <span class="req-pressure">
          <span class="samples">pressure</span>
          <span class="big"><%= t.pressure %></span>
          <span class="samples"><%= t.distinct_records %> rec</span>
        </span>
      </div>

      <div class="req-evidence">
        <%# v0.54: the FULL considerer rationale (the decision basis) is shown untruncated;
            the model's per-record evidence — every rationale + example — is one click away in
            full (no dead-end "…"); and a map recommendation reveals what already lives under
            the suggested target so the reviewer can judge the fit. %>
        <div><%= truncate(t.sample_rationale.to_s, length: 240) %></div>

        <% ev = @evidence[key] || [] %>
        <% if ev.any? %>
          <details class="req-more">
            <summary class="samples">Evidence — <%= pluralize(ev.size, "record") %><%= " (of #{t.distinct_records})" if t.distinct_records.to_i > ev.size %></summary>
            <div class="req-evidence-full">
              <% ev.each do |e| %>
                <div class="ev-row">
                  <div class="ev-source"><% if e[:position] %><span class="ev-pos"><%= e[:position] %></span> <% end %><%= e[:source] ? link_to(e[:source], status_record_path(e[:type], e[:id])) : "—" %></div>
                  <div><%= e[:rationale] %></div>
                  <% if e[:example].present? %>
                    <div class="samples"><em><%= e[:example].is_a?(String) ? e[:example] : e[:example].to_json %></em></div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>

        <div class="considerer">
          <% if t.recommended_decision.present? %>
            <div class="considerer-head">
              <span class="badge-live"><%= t.recommended_decision %><%= " → #{t.recommended_map_to}" if t.recommended_map_to.present? %><% if t.recommended_confidence %> · <%= (t.recommended_confidence.to_f * 100).round %>%<% end %></span>
              <% if low_conf %><span class="chip warn" title="below the considerer's auto-apply floor — pre-filled, but verify before accepting">⚠ low confidence</span><% end %>
            </div>
            <div class="samples considerer-rationale"><%= t.recommended_rationale %></div>

            <% if rec_pending %>
              <div class="samples warn" style="margin-top:.2rem">
                recommended target <code><%= rec_target %></code> is still pending — approve it first to map onto it.
              </div>
            <% elsif rec_target %>
              <%# map-target inspection: the definition of the suggested term + what's already folded onto it %>
              <% variants = @target_variants[rec_target] || [] %>
              <details class="req-more">
                <summary class="samples">Map target <code><%= rec_target %></code> — <%= pluralize(variants.size, "variant") %> already fold here</summary>
                <div class="target-info">
                  <% if @vocab[rec_target].present? %>
                    <div class="samples"><strong>definition:</strong> <%= @vocab[rec_target] %></div>
                  <% end %>
                  <% if variants.any? %>
                    <div class="target-vars"><% variants.each do |v| %><span class="chip"><%= v %></span><% end %></div>
                  <% else %>
                    <div class="samples">nothing folds onto it yet — this would be the first.</div>
                  <% end %>
                  <div class="samples" style="margin-top:.3rem"><%= link_to "see it on Vocabulary →", vocabulary_path %></div>
                </div>
              </details>
            <% end %>
          <% else %>
            <span class="samples">considerer: <span class="muted">—</span></span>
          <% end %>
        </div>
      </div>

      <%# v0.53: markup order stays Approve · Map · Reject; the .rec-* class reorders the
          RECOMMENDED action to the top (flex `order`) and greens it, so the reviewer's eye
          lands on the one-click accept. Map target is a type-ahead over the shared datalist
          (the list is long — pre-filled + filterable beats a 60-item scroll). %>
      <div class="req-actions verdict rec-<%= rec.presence || 'none' %>">
        <%= button_to "Approve", suggestions_verdict_path,
              params: { proposed_key: key, decision: "approve" },
              class: "btn act-approve #{'btn-affirmative' if rec == 'approve' || rec.blank?}" %>
        <%= form_with url: suggestions_verdict_path, method: :post, html: { class: "verdict-map act-map" } do |f| %>
          <%= f.hidden_field :proposed_key, value: key %>
          <%= f.hidden_field :decision, value: "map" %>
          <input class="field" type="text" name="mapped_to" list="canonical-terms"
                 value="<%= prefill %>" placeholder="map onto…" autocomplete="off"
                 aria-label="map <%= key %> onto a preferred term">
          <%= f.submit "Map", class: "btn #{'btn-affirmative' if rec == 'map'}" %>
        <% end %>
        <%= button_to "Reject", suggestions_verdict_path,
              params: { proposed_key: key, decision: "reject" }, class: "btn btn-destructive act-reject" %>
      </div>
    </div>
  <% end %>
<% else %>
  <p class="muted">No pending requests — the vocabulary is fully tended.</p>
<% end %>

<% if @reproposed.any? %>
  <h2>Re-proposed after a verdict <span class="subtitle">— the model is overruling you</span></h2>
  <p class="muted">
    These keys got a verdict, but the model keeps asking for them on later tends. Each re-ask is
    <strong>suppressed</strong> (it doesn't re-flood the queue) and counted here. High counts mean the
    verdict and the data disagree — worth reconsidering.
  </p>
  <div class="card">
    <table>
      <tr><th>proposed key</th><th>your verdict</th><th>times re-asked</th></tr>
      <% @reproposed.each do |t| %>
        <% v = @verdicts[t.proposed_key] %>
        <tr>
          <td><code><%= t.proposed_key %></code></td>
          <td>
            <% if v %>
              <% if v[:status] == "mapped" %>
                <span class="chip">mapped → <code><%= v[:mapped_to] %></code></span>
              <% else %>
                <span class="chip"><%= v[:status] %></span>
              <% end %>
            <% else %>
              <span class="muted">resolved</span>
            <% end %>
          </td>
          <td><span class="big" style="font-size:1.15rem"><%= t.post_verdict_attempts %></span></td>
        </tr>
      <% end %>
    </table>
  </div>
<% end %>

<% if @additions.any? %>
  <h2>Approved &amp; live — codify in your policy</h2>
  <p class="muted">These terms are <strong>already live</strong> in the controlled vocabulary — the model emits them as claims now. Paste them into the matching <code>facet</code> in your staffing policy initializer to make them a permanent, versioned code artifact (after which this DB-derived addition is redundant).</p>
  <% @additions.each do |facet, keys| %>
    <div class="card">
      <div class="muted">facet <code><%= facet %></code></div>
<pre class="mono" style="white-space:pre-wrap; margin:.4rem 0 0">terms: {
<% keys.each do |k| -%>
  <%= k %>: "TODO: describe <%= k %>",
<% end -%>
}</pre>
    </div>
  <% end %>
<% end %>

<% if @synonyms.any? %>
  <h2>USE references <span class="subtitle">— synonyms folded onto a preferred term</span></h2>
  <div class="card">
    <table>
      <tr><th>variant (UF)</th><th>USE →</th><th>facet</th></tr>
      <% @synonyms.each do |s| %>
        <tr><td><code><%= s[:proposed_key] %></code></td><td><code><%= s[:mapped_to] %></code></td><td class="samples"><%= s[:facet] %></td></tr>
      <% end %>
    </table>
  </div>
<% end %>

<% if @running %>
<%# v0.48: inline poll loop — mirrors heartbeat/index.html.erb's pattern exactly.
    ALL inline (hard rule 2: no asset pipeline / CDN / gems). %>
<script>
(function () {
  var el       = document.getElementById("monitor");
  var pulseUrl = el.getAttribute("data-pulse-url");
  var planned  = parseInt(el.getAttribute("data-planned"), 10) || 0;
  var bar      = document.getElementById("bar");
  var doneEl   = document.getElementById("done-count");
  var totalEl  = document.getElementById("total-count");
  var phaseEl  = document.getElementById("phase-label");
  var banner   = document.getElementById("banner");
  var finish   = document.getElementById("finish");
  var failures = 0;

  function render(p) {
    failures = 0;
    banner.className = "pulse-banner";   // clear any stall/unreachable banner

    var done  = p.done_count  || 0;
    var total = p.planned_count || planned;
    doneEl.textContent  = done;
    totalEl.textContent = total;
    bar.style.width = total > 0 ? Math.min(100, Math.round(done / total * 100)) + "%" : "0%";

    if (p.finished) {
      phaseEl.textContent = "";
      bar.style.width = "100%";
      var html = p.error
        ? '<div class="pulse-banner warn-bg" style="display:block">Run aborted — ' + p.error + '</div>'
        : '<div class="muted" style="margin-top:.5rem"><strong>Done.</strong>' +
          (p.summary ? ' Considered ' + (p.summary.considered || 0) + ' term(s): ' +
            'auto-mapped ' + (p.summary.auto_mapped || 0) + ', auto-rejected ' +
            (p.summary.auto_rejected || 0) + ', ' +
            (p.summary.approves_recommended || 0) + ' approval(s) recommended.' : '') +
          '</div>';
      finish.innerHTML = html;
      setTimeout(function () { location.reload(); }, 3000);
      return;
    }

    // Stall check — keyed to pulse_at, fires in every phase.
    if (p.stalled) {
      banner.className = "pulse-banner warn-bg";
      banner.textContent = "No sign of life for several minutes" +
        (p.phase ? " (last seen: " + p.phase + ")" : "") +
        " — the run may have crashed (server restart?). Reload to check.";
    } else {
      phaseEl.textContent = p.phase ? "running " + p.phase + "…" : "";
    }

    setTimeout(function tick() { pollOnce(); }, 2000);
  }

  function pollOnce() {
    fetch(pulseUrl, { headers: { "Accept": "application/json" } })
      .then(function (r) { if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(render)
      .catch(function () {
        failures += 1;
        if (failures >= 5) {
          banner.className = "pulse-banner warn-bg";
          banner.textContent = "Server unreachable — still trying. If it restarted, the run died with it.";
        }
        setTimeout(function tick() { pollOnce(); }, 2000);
      });
  }

  pollOnce();
})();
</script>
<% end %>

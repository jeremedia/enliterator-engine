<h1>Chat with the enliteration</h1>
<p class="muted">A reference interview with the collection: ask about it as a whole, or about anything it has tended. Answers are grounded in the self-portrait below plus the records retrieved per question — follow a source chip to the record and ask again, the way discovery actually works.</p>

<%# The scope banner. The context cookie persists silently across visits, and
    the selected context changes EVERYTHING about this page (the self-portrait,
    the retrieval pool, the claims read) — so the scope must be stated where
    the conversation happens, not only in the nav's small selector. %>
<% if current_context %>
  <div class="card" style="padding:.6rem 1.1rem; border-left:3px solid var(--accent)">
    <strong<% if Enliterator.configuration.chat_federation %> id="enl-scope-banner"<% end %>>Asking within: <%= current_context.name %></strong>
    <span class="muted">— <%= @scope_count %> member record(s). Answers retrieve only this collection's
    members, read through its lens (plus inherited claims).</span>
    <%= link_to "ask the whole collection instead →", conversation_path(context: "root"),
                class: "samples", style: "white-space:nowrap" %>
  </div>
<% else %>
  <p class="muted samples" style="margin-top:-.4rem"<% if Enliterator.configuration.chat_federation %> id="enl-scope-banner"<% end %>>
    Asking the <strong>whole collection</strong> — every context's records are in the retrieval pool.
    <% if context_switcher_options.any? %>Narrow to one collection with the context selector in the nav.<% end %>
  </p>
<% end %>

<details class="card">
  <summary>What this collection knows about itself</summary>
  <pre class="mono" style="white-space:pre-wrap; margin:.6rem 0 0"><%= Enliterator::Synopsis.to_prompt(@synopsis) %></pre>
</details>

<div id="thread" class="thread"></div>

<div class="prompts" id="prompts">
  <span class="label">Try asking:</span>
  <button type="button" class="prompt">What's interesting about this collection?</button>
  <button type="button" class="prompt">What does this collection know about itself?</button>
  <button type="button" class="prompt">What are the strongest recurring themes, and which records anchor them?</button>
  <button type="button" class="prompt">Where is this collection's knowledge thin or uneven?</button>
</div>

<form id="ask" class="ask">
  <textarea id="q" placeholder="e.g. What does this collection know about itself? Which records connect to X?" rows="2"></textarea>
  <button id="send" type="submit">Send</button>
</form>

<script>
(function () {
  var streamUrl = "<%= conversation_stream_path %>";
  var statusBase = "<%= status_path %>"; // /…/status ; record path is statusBase + "/Type/id"
  var csrf = (document.querySelector('meta[name="csrf-token"]') || {}).content || "";
  var thread = document.getElementById("thread");
  var form = document.getElementById("ask");
  var input = document.getElementById("q");
  var send = document.getElementById("send");
  var history = [];

  // --- compact, safe markdown -> HTML (no deps). Escapes first, then formats the
  //     subset LLMs emit: headers, bold/italic, inline code, blockquotes, rules,
  //     bullet/numbered lists (incl. nested), pipe tables, links, paragraphs.
  //     HTML in the source is neutralized (esc) BEFORE any formatting — every
  //     matcher below operates on already-escaped text, so no branch can open an
  //     XSS hole. The extension is additive: input that uses none of the v0.29
  //     syntax (>, ---, | tables |, indented list items) renders byte-identically
  //     to the prior version (guarded by spec/javascript/md_golden.test.js). ---
  function esc(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }
  function inline(s) {
    // s is already HTML-escaped, so a link URL cannot contain a raw quote. We
    // ALSO reject non-http(s)/mailto schemes (javascript:, data:, vbscript:) so
    // untrusted document text the model may echo into a [label](url) can never
    // become a live javascript: href. Scheme-less (relative/anchor) URLs pass.
    return s
      .replace(/`([^`]+)`/g, "<code>$1</code>")
      .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, function (_m, text, url) {
        var sch = url.match(/^([a-z][a-z0-9+.\-]*):/i);
        var ok = !sch || /^(https?|mailto)$/i.test(sch[1]);
        return ok ? '<a href="' + url + '" target="_blank" rel="noopener">' + text + "</a>" : text;
      })
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/(^|[\s(])\*([^*\n]+)\*/g, "$1<em>$2</em>")
      .replace(/(^|[\s(])_([^_\n]+)_/g, "$1<em>$2</em>");
    }
  function mdToHtml(src) {
    var lines = esc(src).split("\n");
    var out = "";

    // ── Nested-list builder ────────────────────────────────────────────────
    // A stack of open lists, each {tag, level}. Flat (level-0) lists produce
    // EXACTLY the prior "<ul><li>x</li>…</ul>" — no nesting markup, byte-identical
    // to the old single-`list` loop. Deeper indent opens a child list INSIDE the
    // current item: we hold the item's "</li>" open, emit the child, then close.
    var listStack = [];
    function closeList() {
      while (listStack.length) {
        var top = listStack.pop();
        out += "</li></" + top.tag + ">";
      }
    }
    // depth math: 0-1 leading spaces = level 0; every additional 2 spaces (or a
    // tab) is one more level. (Markdown emitters use 2- or 4-space indents; we
    // bucket both — a 4-space child still lands one level deeper than its parent.)
    function indentLevel(spaces) {
      var n = spaces.replace(/\t/g, "  ").length;
      return Math.floor(n / 2);
    }
    function listItem(tag, level, text) {
      // pop deeper / equal-but-different-tag lists down to this level
      while (listStack.length &&
             (listStack[listStack.length - 1].level > level ||
              (listStack[listStack.length - 1].level === level &&
               listStack[listStack.length - 1].tag !== tag))) {
        var top = listStack.pop();
        out += "</li></" + top.tag + ">";
      }
      var cur = listStack[listStack.length - 1];
      if (!cur || cur.level < level) {
        // open a new (possibly nested) list. When nesting, the parent's <li> is
        // still open — the child <ul>/<ol> renders inside it.
        out += "<" + tag + "><li>";
        listStack.push({ tag: tag, level: level });
      } else {
        // sibling item at this level: close the previous item, open a new one
        out += "</li><li>";
      }
      out += inline(text);
    }

    // ── Table detection: a header row + a delimiter row of dashes. ──────────
    function tableCells(row) {
      var t = row.trim().replace(/^\|/, "").replace(/\|$/, "");
      return t.split("|").map(function (c) { return c.trim(); });
    }
    // A delimiter row: contains a pipe (so a bare "---" stays a horizontal rule,
    // never a table separator) AND every pipe-separated cell is dashes with
    // optional alignment colons (`:--`, `--:`, `:-:`). Single- and multi-column
    // delimiters both pass.
    function isTableDelim(row) {
      if (row.indexOf("|") === -1) return false;
      return tableCells(row).every(function (c) { return /^:?-{1,}:?$/.test(c); });
    }

    for (var i = 0; i < lines.length; i++) {
      var ln = lines[i];

      // Pipe table: a header row immediately followed by a delimiter row. Detect
      // BEFORE the hr branch so a "---"-style delimiter under a header is read as
      // a table separator, not a horizontal rule.
      var next = lines[i + 1];
      if (ln.indexOf("|") !== -1 && next !== undefined && isTableDelim(next) &&
          ln.trim() !== "" && !/^\s*#{1,6}\s/.test(ln)) {
        closeList();
        var headers = tableCells(ln);
        out += "<table><thead><tr>";
        headers.forEach(function (c) { out += "<th>" + inline(c) + "</th>"; });
        out += "</tr></thead><tbody>";
        i += 2; // consume header + delimiter
        for (; i < lines.length; i++) {
          var row = lines[i];
          if (row.trim() === "" || row.indexOf("|") === -1) { i--; break; }
          var cells = tableCells(row);
          out += "<tr>";
          // pad/truncate to the header width so ragged rows stay well-formed
          for (var c = 0; c < headers.length; c++) {
            out += "<td>" + inline(cells[c] !== undefined ? cells[c] : "") + "</td>";
          }
          out += "</tr>";
        }
        out += "</tbody></table>";
        continue;
      }

      var h = ln.match(/^(#{1,6})\s+(.*)$/);
      // Horizontal rule: a WHOLE line of 3+ of a single mark (-, *, _), optionally
      // surrounded by whitespace. The single-char class (no mixing) means "**" or
      // "--" or a bold lead never matches; the table branch above already claimed
      // any "---" acting as a table delimiter.
      var hr = /^\s*([-*_])\1{2,}\s*$/.test(ln);
      // blockquote marker: esc() has already turned a leading ">" into "&gt;",
      // so match the ESCAPED form (operating on escaped text — XSS-safe).
      var bq = ln.match(/^\s*&gt;\s?(.*)$/);
      var ul = ln.match(/^(\s*)[-*]\s+(.*)$/);
      var ol = ln.match(/^(\s*)\d+\.\s+(.*)$/);

      if (h) { closeList(); var lvl = Math.min(h[1].length + 1, 6); out += "<h" + lvl + ">" + inline(h[2]) + "</h" + lvl + ">"; }
      else if (hr) { closeList(); out += "<hr>"; }
      else if (bq) {
        // gather consecutive blockquote lines into one <blockquote>; a blank
        // line (or any non-> line) ends it. Inner lines join with <br>.
        closeList();
        var quoted = [ inline(bq[1]) ];
        while (i + 1 < lines.length) {
          var q = lines[i + 1].match(/^\s*&gt;\s?(.*)$/);
          if (!q) break;
          quoted.push(inline(q[1]));
          i++;
        }
        out += "<blockquote>" + quoted.join("<br>") + "</blockquote>";
      }
      else if (ul) { listItem("ul", indentLevel(ul[1]), ul[2]); }
      else if (ol) { listItem("ol", indentLevel(ol[1]), ol[2]); }
      else if (ln.trim() === "") { closeList(); }
      else { closeList(); out += "<p>" + inline(ln) + "</p>"; }
    }
    closeList();
    return out;
  }

  function userBubble(text) {
    var el = document.createElement("div");
    el.className = "bubble user";
    el.textContent = text;
    thread.appendChild(el);
    thread.scrollTop = thread.scrollHeight;
  }
  function assistantBubble() {
    var el = document.createElement("div"); el.className = "bubble assistant";
    var md = document.createElement("div"); md.className = "md"; md.textContent = "…";
    var prov = document.createElement("div"); prov.className = "provenance";
    el.appendChild(md); el.appendChild(prov);
    thread.appendChild(el); thread.scrollTop = thread.scrollHeight;
    return { md: md, prov: prov };
  }

  function renderProvenance(provEl, records, contextKey) {
    // Stamp the answer with the scope that produced it (non-root only — the
    // banner above carries the root case). Self-describing transcripts.
    if (contextKey && contextKey !== "root") {
      var scope = document.createElement("span");
      scope.className = "muted samples";
      scope.style.marginRight = ".4rem";
      scope.textContent = "asked in " + contextKey + " ·";
      provEl.appendChild(scope);
    }
    if (!records || !records.length) return;
    records.forEach(function (r) {
      var a = document.createElement("a");
      a.className = "chip";
      a.href = statusBase + "/" + encodeURIComponent(r.type) + "/" + encodeURIComponent(r.id);
      a.textContent = r.label || (r.type + "/" + r.id);
      provEl.appendChild(a);
    });
  }

  function scheduleRender(els, state) {
    if (state.timer) return;
    state.timer = setTimeout(function () {
      state.timer = null;
      els.md.innerHTML = mdToHtml(state.text);
      thread.scrollTop = thread.scrollHeight;
    }, 70);
  }

  function handleFrame(frame, els, state) {
<% if Enliterator.configuration.chat_federation %>
    return handleFrameFederated(frame, els, state);
<% end %>
    var ev = "message", data = "";
    frame.split("\n").forEach(function (line) {
      if (line.indexOf("event:") === 0) ev = line.slice(6).trim();
      else if (line.indexOf("data:") === 0) data += line.slice(5).trim();
    });
    if (!data) return;
    var payload; try { payload = JSON.parse(data); } catch (e) { return; }
    if (ev === "token") { state.text += payload.t || ""; scheduleRender(els, state); }
    else if (ev === "provenance") { renderProvenance(els.prov, payload.records, payload.context); }
    else if (ev === "error") { state.text += "\n\n_[" + (payload.message || "error") + "]_"; }
  }

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    submitQuestion((input.value || "").trim());
  });

  // Click-to-populate starter prompts: fill the box (so the user sees it), then send.
  document.querySelectorAll("#prompts button.prompt").forEach(function (b) {
    b.addEventListener("click", function () {
      if (send.disabled) return;            // a stream is in flight
      input.value = b.textContent.trim();   // populate
      submitQuestion(input.value);          // then send
    });
  });

  function submitQuestion(q) {
<% if Enliterator.configuration.chat_federation %>
    return submitQuestionFederated(q);
<% end %>
    if (!q) return;
    userBubble(q);
    var els = assistantBubble();
    var state = { text: "", timer: null };
    input.value = ""; send.disabled = true;

    var body = new FormData();
    body.append("question", q);
    body.append("history", JSON.stringify(history));

    fetch(streamUrl, { method: "POST", headers: { "X-CSRF-Token": csrf }, body: body })
      .then(function (resp) {
        var reader = resp.body.getReader();
        var decoder = new TextDecoder();
        var buf = "";
        function pump() {
          return reader.read().then(function (res) {
            if (res.done) {
              if (state.timer) { clearTimeout(state.timer); state.timer = null; }
              els.md.innerHTML = mdToHtml(state.text); // final flush
              history.push({ role: "user", content: q });
              history.push({ role: "assistant", content: state.text });
              send.disabled = false;
              return;
            }
            buf += decoder.decode(res.value, { stream: true });
            var parts = buf.split("\n\n");
            buf = parts.pop();
            parts.forEach(function (f) { handleFrame(f, els, state); });
            return pump();
          });
        }
        return pump();
      })
      .catch(function () {
        els.md.innerHTML = mdToHtml(state.text + "\n\n_[connection error]_");
        send.disabled = false;
      });
  }
<% if Enliterator.configuration.chat_federation %>
  // ── Federation: the agentic turn model ──────────────────────────────────
  // A turn reads top-to-bottom as a narrative: the live work-trace first, the
  // answer below it (created lazily on the first token so it lands UNDER the
  // trace), then an empty sources zone a later task populates. Tool calls show
  // live status (spinner → ✓) so the ~20s Bedrock turns aren't dead air.
  var TOOL_LABELS = {
    collection_overview: "Reading the collection's self-portrait",
    search:              "Searching the collection",
    subject_search:      "Looking up a subject heading",
    browse_subjects:     "Browsing subject headings",
    vocabulary:          "Checking the controlled vocabulary",
    record_entry:        "Pulling a record's full entry",
    connections:         "Tracing connections",
    trajectory:          "Tracing how understanding deepened",
    provenance:          "Checking a claim's provenance",
    quote:               "Finding the source passage",
    accuracy:            "Checking audited accuracy",
    recent_activity:     "Reviewing recent activity",
    route_to:            "Routing to a specialist desk"
  };
  function toolLabel(name) { return TOOL_LABELS[name] || ("Consulting " + (name || "a tool")); }

  // ── Citations: the "infrastructure is the argument" surface ──────────────
  // A grounded answer connects to the records the desk actually consulted. As
  // tool widgets stream into the trace, every [data-enl-id] element registers a
  // record (deduped by type/id, numbered in first-seen order). On turn
  // completion: a "Sources consulted" rail (always-correct — it mirrors the
  // trace, independent of whether the prose mentions anything), and best-effort
  // inline chips wrapping conservative label matches in the answer. The DOM
  // matches the layout's pre-existing .enl-cite* / .enl-sources* CSS.

  var SOURCE_PATH_BASE = statusBase; // record path = statusBase + "/Type/id"

  // The URL for a consulted record: prefer the tool-provided entry path (already
  // correct, server-built), else reconstruct it the way the single-shot
  // renderProvenance does (statusBase + "/Type/id"). Same construction either way.
  function citeUrl(rec) {
    if (rec.entry) return rec.entry;
    return SOURCE_PATH_BASE + "/" + encodeURIComponent(rec.type) + "/" + encodeURIComponent(rec.id);
  }

  // Harvest record identities from one rendered widget body into the turn's
  // registry. Reads the data-enl-* attributes the widgets now emit. Deduped by
  // "type/id"; an unlabeled record still registers (the rail shows its type/id).
  function harvestCites(els, root) {
    if (!root) return;
    var nodes = root.querySelectorAll("[data-enl-id]");
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var type = n.getAttribute("data-enl-type") || "";
      var id = n.getAttribute("data-enl-id") || "";
      if (!id) continue;
      var key = type + "/" + id;
      if (els.cites.seen[key]) continue;
      els.cites.seen[key] = true;
      els.cites.list.push({
        type: type, id: id,
        label: n.getAttribute("data-enl-label") || "",
        entry: n.getAttribute("data-enl-entry") || ""
      });
    }
  }

  // The sources rail: one numbered item per consulted record. Empty registry →
  // leave .enl-sources empty (no orphan header). Built with textContent + DOM
  // nodes (never innerHTML of record data) — escaping by construction.
  function renderSourcesRail(els) {
    var sources = els.sources;
    if (!sources || !els.cites.list.length) return; // empty → no rail (clean, rule 3)
    sources.textContent = "";
    var head = document.createElement("div");
    head.className = "enl-sources__head";
    head.textContent = "Sources consulted";
    sources.appendChild(head);
    els.cites.list.forEach(function (rec, idx) {
      var item = document.createElement("div");
      item.className = "enl-sources__item";
      var num = document.createElement("span");
      num.className = "enl-sources__num";
      num.textContent = "[" + (idx + 1) + "]";
      var link = document.createElement("a");
      link.href = citeUrl(rec);
      link.textContent = rec.label || (rec.type + "/" + rec.id);
      var type = document.createElement("span");
      type.className = "muted";
      type.textContent = rec.type;
      item.appendChild(num);
      item.appendChild(link);
      item.appendChild(type);
      sources.appendChild(item);
    });
  }

  // Inline chips: post-process the rendered answer to superscript a numbered
  // chip after a conservative match of a consulted record's label. Operates ONLY
  // on text nodes (never on tags/hrefs) so it can't corrupt existing markup or
  // open an injection hole. Conservative by design — false silence beats false
  // positives: labels shorter than the floor are skipped, longest labels match
  // first, each label is wrapped at most once. No match → no chips (the rail
  // still stands; rule 3, graceful).
  var CITE_MIN_LABEL = 12;

  function annotateCites(els) {
    if (!els.md || !els.cites.list.length) return;
    // Candidates: [label, refNumber] for labels long/specific enough to match
    // safely. Sort longest-first so "United States Coast Guard" wins over a
    // substring label. Track which refs we've already placed (cap: once each).
    var candidates = [];
    els.cites.list.forEach(function (rec, idx) {
      var label = (rec.label || "").trim();
      if (label.length < CITE_MIN_LABEL) return; // too short → skip (false-positive guard)
      candidates.push({ label: label, ref: idx + 1, rec: rec });
    });
    if (!candidates.length) return;
    candidates.sort(function (a, b) { return b.label.length - a.label.length; });

    var placed = {}; // ref → true once a chip is placed
    candidates.forEach(function (cand) {
      if (placed[cand.ref]) return;
      if (wrapFirstMatch(els.md, cand.label, cand)) placed[cand.ref] = true;
    });
  }

  // Walk text nodes under `root`; on the first node containing `needle` (literal,
  // case-insensitive), split the node and insert a citation chip right after the
  // matched text. Returns true if a chip was placed. Skips text already inside a
  // link or an existing chip (don't nest chips, don't break anchors).
  function wrapFirstMatch(root, needle, cand) {
    var lc = needle.toLowerCase();
    var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, null);
    var node;
    while ((node = walker.nextNode())) {
      var parent = node.parentNode;
      if (!parent) continue;
      if (parent.closest && parent.closest("a, .enl-cite")) continue; // never inside a link/chip
      var hay = node.nodeValue;
      var at = hay.toLowerCase().indexOf(lc);
      if (at === -1) continue;
      var after = node.splitText(at + needle.length); // node now ends at the match; `after` is the tail
      var chip = makeCiteChip(cand);
      parent.insertBefore(chip, after);
      return true;
    }
    return false;
  }

  // One citation chip: a <button> (keyboard-accessible) showing [n]; click →
  // the record URL; hover/focus → a popover with the record's label + type. All
  // record text set via textContent — no innerHTML of untrusted strings.
  function makeCiteChip(cand) {
    var btn = document.createElement("button");
    btn.type = "button";
    btn.className = "enl-cite";
    btn.setAttribute("data-ref", String(cand.ref));
    btn.textContent = String(cand.ref);
    btn.setAttribute("aria-label", "Source " + cand.ref + ": " + (cand.rec.label || cand.rec.type));
    var url = citeUrl(cand.rec);
    btn.addEventListener("click", function () { window.location.href = url; });
    var pop = null;
    function show() {
      if (pop) return;
      pop = buildCitePop(cand.rec);
      // position within the positioned .enl-turn ancestor, just under the chip
      var turn = btn.closest(".enl-turn") || document.body;
      turn.appendChild(pop);
      var tr = turn.getBoundingClientRect();
      var br = btn.getBoundingClientRect();
      pop.style.left = (br.left - tr.left) + "px";
      pop.style.top = (br.bottom - tr.top + 4) + "px";
    }
    function hide() { if (pop) { pop.remove(); pop = null; } }
    btn.addEventListener("mouseenter", show);
    btn.addEventListener("mouseleave", hide);
    btn.addEventListener("focus", show);
    btn.addEventListener("blur", hide);
    return btn;
  }

  function buildCitePop(rec) {
    var pop = document.createElement("div");
    pop.className = "enl-cite__pop";
    var label = document.createElement("span");
    label.className = "label";
    label.textContent = rec.label || (rec.type + "/" + rec.id);
    var type = document.createElement("span");
    type.className = "type";
    type.textContent = rec.type;
    pop.appendChild(label);
    pop.appendChild(type);
    return pop;
  }

  // ── Actionable error card (v0.30) ───────────────────────────────────────
  // Render a structured :error payload as a readable card. The server sends
  // {message:} always, plus {detail:, where:, hint:} when error_detail is on
  // (dev). EVERY payload value is written via textContent — NEVER innerHTML —
  // so an injected <script>/<img onerror> in any field is inert text, not live
  // markup (the payload is server JSON but treated as untrusted; hard rule 2).
  // The card lands where the answer renders: if the turn already has an answer
  // bubble (els.md) we append into it (so a model-call error sits in the answer
  // position, below the trace); otherwise we open the answer bubble and use it;
  // a bare fallback appends to the turn so the card is always visible (rule 3).
  function renderErrorCard(els, payload) {
    payload = payload || {};
    var card = document.createElement("div");
    card.className = "enl-error";

    var msg = document.createElement("div");
    msg.className = "enl-error__msg";
    msg.textContent = payload.message || "Something went wrong";
    card.appendChild(msg);

    if (payload.detail) {
      var detail = document.createElement("div");
      detail.className = "enl-error__detail";
      detail.textContent = payload.detail; // "Class: message" — textContent, inert
      card.appendChild(detail);
    }
    if (payload.where) {
      var where = document.createElement("div");
      where.className = "enl-error__where";
      where.textContent = payload.where; // "model call · CHDS Theses · bedrock-sonnet"
      card.appendChild(where);
    }
    if (payload.hint) {
      var hint = document.createElement("div");
      hint.className = "enl-error__hint";
      hint.textContent = "→ " + payload.hint; // the actionable remediation
      card.appendChild(hint);
    }

    // Placement: prefer the answer container (so the error replaces/sits where
    // the answer would). ensureAnswer opens the bubble + sets els.md if absent;
    // if even that isn't available, fall back to the turn.
    if (typeof ensureAnswer === "function" && !els.md) ensureAnswer(els);
    if (els.md) {
      // The answer bubble may still hold the typing-indicator placeholder
      // (innerHTML set in ensureAnswer); clear it so the card stands alone.
      els.md.textContent = "";
      els.md.appendChild(card);
    } else if (els.turn) {
      els.turn.appendChild(card);
    } else {
      thread.appendChild(card);
    }
    thread.scrollTop = thread.scrollHeight;
    return card;
  }

  // Build the ordered turn container. style="position:relative" gives a later
  // task's citation popover a positioned ancestor.
  function buildTurn() {
    var turn = document.createElement("div");
    turn.className = "enl-turn";
    turn.style.position = "relative";

    var trace = document.createElement("div");
    trace.className = "enl-trace";
    trace.setAttribute("data-state", "working");
    var head = document.createElement("div");
    head.className = "enl-trace__head";
    head.textContent = "Working at the Frontdesk…";
    var steps = document.createElement("div");
    steps.className = "enl-trace__steps";
    trace.appendChild(head); trace.appendChild(steps);

    var sources = document.createElement("div");
    sources.className = "enl-sources"; // left empty; a later task populates it

    turn.appendChild(trace);
    // answer bubble is created lazily (on the first token) so it lands here,
    // BETWEEN the trace and the sources zone.
    turn.appendChild(sources);
    thread.appendChild(turn);
    thread.scrollTop = thread.scrollHeight;
    return { turn: turn, trace: trace, head: head, steps: steps, sources: sources };
  }

  // Create the answer bubble lazily, inserted directly after the trace (so it
  // renders below the work-trace and above the sources zone). The bubble opens on
  // a typing indicator (reusing the layout's already-animated .enl-typing dots) so
  // the wait before the first token isn't dead air; scheduleRender replaces the
  // dots with the streamed answer on the first render, and the final flush in
  // finishTurnFederated guarantees they never strand (rule 3).
  function ensureAnswer(els) {
    if (els.md) return;
    var bubble = document.createElement("div"); bubble.className = "bubble assistant";
    var md = document.createElement("div"); md.className = "md";
    md.innerHTML = '<span class="enl-typing" aria-label="thinking"><span></span><span></span><span></span></span>';
    var prov = document.createElement("div"); prov.className = "provenance";
    bubble.appendChild(md); bubble.appendChild(prov);
    els.trace.insertAdjacentElement("afterend", bubble);
    els.md = md; els.prov = prov;
    thread.scrollTop = thread.scrollHeight;
  }

  function traceStep(label, activeDesk) {
    var step = document.createElement("div");
    step.className = "enl-trace__step enl-trace__step--working";
    var dot = document.createElement("span"); dot.className = "enl-trace__dot";
    var lab = document.createElement("span"); lab.className = "enl-trace__label";
    lab.appendChild(document.createTextNode(label));
    var desk = document.createElement("span"); desk.className = "desk";
    desk.textContent = " · at the " + activeDesk + " desk";
    lab.appendChild(desk);
    step.appendChild(dot); step.appendChild(lab);
    return step;
  }

  // Non-destructive scope-banner update: keep the original "Asking within: …"/
  // "Asking the whole collection" text; append/update a child span noting the
  // desk we routed to.
  function noteActiveDesk(desk) {
    var banner = document.getElementById("enl-scope-banner");
    if (!banner) return;
    var active = banner.querySelector(".enl-active-desk");
    if (!active) {
      active = document.createElement("span");
      active.className = "enl-active-desk";
      banner.appendChild(active);
    }
    active.textContent = " — now at the " + desk + " desk";
  }

  function handleFrameFederated(frame, els, state) {
    var ev = "message", data = "";
    frame.split("\n").forEach(function (line) {
      if (line.indexOf("event:") === 0) ev = line.slice(6).trim();
      else if (line.indexOf("data:") === 0) data += line.slice(5).trim();
    });
    if (!data) return;
    var payload; try { payload = JSON.parse(data); } catch (e) { return; }

    if (ev === "token") {
      ensureAnswer(els);
      state.text += payload.t || ""; scheduleRender(els, state);
    }
    else if (ev === "provenance") {
      ensureAnswer(els);
      renderProvenance(els.prov, payload.records, payload.context);
    }
    else if (ev === "error") {
      // v0.30: render the structured payload as an actionable card (replaces the
      // old inline-italic-into-the-answer). message-only in prod, +detail/where/
      // hint in dev — all via textContent (renderErrorCard).
      renderErrorCard(els, payload);
    }
    else if (ev === "tool_call_start") {
      var step = traceStep(toolLabel(payload.name), els.activeDesk);
      els.steps.appendChild(step);
      // Keyed by tool name. Safe because the loop emits start→result synchronously
      // around one Mcp.dispatch, so same-name calls never overlap (the result clears
      // the key before the next same-name start). If parallel/batched same-name tool
      // calls ever land, key by a unique call id instead, or the earlier step orphans.
      els.toolSteps[payload.name] = step;
      thread.scrollTop = thread.scrollHeight;
    }
    else if (ev === "tool_call_result") {
      var s = els.toolSteps[payload.name];
      if (!s) { // defensive: no matching start tracked — still surface a done step
        s = traceStep(toolLabel(payload.name), els.activeDesk);
        els.steps.appendChild(s);
      }
      s.className = "enl-trace__step enl-trace__step--done";
      delete els.toolSteps[payload.name];
      var det = document.createElement("details");
      var sum = document.createElement("summary"); sum.textContent = "view";
      var body = document.createElement("div"); body.innerHTML = payload.html || "";
      det.appendChild(sum); det.appendChild(body);
      s.appendChild(det);
      els.sourceCount++;
      harvestCites(els, body); // v0.29: register any [data-enl-id] records from this widget
      thread.scrollTop = thread.scrollHeight;
    }
    else if (ev === "tool_call_error") {
      var es = els.toolSteps[payload.name];
      if (!es) { // defensive: no matching start tracked — build the error step fresh
        es = traceStep(toolLabel(payload.name), els.activeDesk);
        els.steps.appendChild(es);
      }
      delete els.toolSteps[payload.name];
      es.className = "enl-trace__step enl-trace__step--error";
      // surface the actual message in the label (rule 3: no silent failure)
      es.querySelector(".enl-trace__label").textContent =
        toolLabel(payload.name) + " — " + (payload.message || "tool error");
      // v0.30: when error_detail is on, a failed tool in the trace shows WHY —
      // the exception detail and the actionable hint, appended under the step.
      // textContent only (payload values are untrusted; XSS-safe).
      if (payload.detail) {
        var tdet = document.createElement("div");
        tdet.className = "enl-error__detail";
        tdet.textContent = payload.detail;
        es.appendChild(tdet);
      }
      if (payload.hint) {
        var thint = document.createElement("div");
        thint.className = "enl-error__hint";
        thint.textContent = "→ " + payload.hint;
        es.appendChild(thint);
      }
      thread.scrollTop = thread.scrollHeight;
    }
    else if (ev === "handoff") {
      var to = payload.to || "another";
      var hand = document.createElement("div"); hand.className = "enl-handoff";
      hand.textContent = "routed to the " + to + " desk";
      els.steps.appendChild(hand);
      els.activeDesk = to;
      noteActiveDesk(to);
      thread.scrollTop = thread.scrollHeight;
    }
    // ev === "done" is handled by the reader-done path in submitQuestionFederated.
  }

  function finishTurnFederated(els, state, q) {
    if (state.timer) { clearTimeout(state.timer); state.timer = null; }
    ensureAnswer(els);
    els.md.innerHTML = mdToHtml(state.text); // final flush
    // v0.29 citations: the sources rail reflects what the desk actually
    // consulted (always-correct, even if no label matched in the prose); the
    // inline chips correlate the answer's text to those records (best-effort —
    // none matching is fine, the rail still stands). Both run AFTER the final
    // mdToHtml flush so they see the complete answer. Order: rail first (so the
    // chips can index into the same numbered list).
    renderSourcesRail(els);
    annotateCites(els);
    // Any tool step still spinning (no result arrived) resolves to done so the
    // trace never strands a spinner (rule 3: no silent in-progress state).
    Object.keys(els.toolSteps).forEach(function (n) {
      els.toolSteps[n].className = "enl-trace__step enl-trace__step--done";
    });
    // Collapse the trace to its head summary; the head re-expands on click.
    els.trace.setAttribute("data-state", "done");
    var n = els.sourceCount;
    els.head.textContent = "Worked through " + n + " source" + (n === 1 ? "" : "s") + " ▸";
    els.head.addEventListener("click", function () { els.trace.classList.toggle("is-open"); });
    history.push({ role: "user", content: q });
    history.push({ role: "assistant", content: state.text });
    sendBusy(false);
    // Derive this turn's follow-up suggestions from the records the desk just
    // consulted (client-side, from the trace). Falls back to the static starters
    // when nothing was consulted — the prompt bar is never left blank (rule 3).
    refreshFollowups(els);
  }

  // Send button working-state: a single source of truth so the catch, the
  // finisher, and the start can't drift. busy(true) disables + shows the working
  // affordance; busy(false) restores the original label (captured once).
  var SEND_LABEL = send.textContent;
  function sendBusy(on) {
    send.disabled = on;
    send.classList.toggle("enl-send--working", on);
    send.textContent = on ? "…" : SEND_LABEL;
  }

  function submitQuestionFederated(q) {
    if (!q) return;
    userBubble(q);
    var t = buildTurn();
    var els = { trace: t.trace, head: t.head, steps: t.steps, sources: t.sources,
                turn: t.turn, md: null, prov: null, toolSteps: {}, activeDesk: "Frontdesk",
                sourceCount: 0,
                // v0.29 citations: the consulted-records registry for THIS turn.
                // `list` is first-seen order ([n] = index+1); `seen` dedupes by
                // type/id. Harvested from tool widgets as they stream in.
                cites: { list: [], seen: {} } };
    var state = { text: "", timer: null };
    input.value = ""; resetTextarea(); sendBusy(true);

    var body = new FormData();
    body.append("question", q);
    body.append("history", JSON.stringify(history));

    fetch(streamUrl, { method: "POST", headers: { "X-CSRF-Token": csrf }, body: body })
      .then(function (resp) {
        var reader = resp.body.getReader();
        var decoder = new TextDecoder();
        var buf = "";
        function pump() {
          return reader.read().then(function (res) {
            if (res.done) { finishTurnFederated(els, state, q); return; }
            buf += decoder.decode(res.value, { stream: true });
            var parts = buf.split("\n\n");
            buf = parts.pop();
            parts.forEach(function (f) { handleFrameFederated(f, els, state); });
            return pump();
          });
        }
        return pump();
      })
      .catch(function () {
        // v0.30: a transport failure has no server payload — render a
        // message-only card (which is correct: no detail is available client-side).
        renderErrorCard(els, { message: "I lost the connection — please try again." });
        els.trace.setAttribute("data-state", "done");
        sendBusy(false);
      });
  }

  // ── Input polish: autosize + Enter-to-submit ────────────────────────────
  // Federation only. The textarea grows to fit its content (height: auto →
  // scrollHeight) up to the CSS cap (--enl-ta-max via .enl-autosize), then
  // scrolls. Enter submits; Shift+Enter inserts a newline. The off path keeps
  // its static rows-based textarea and default Enter-inserts-newline behavior —
  // none of this runs there because the whole block is ERB-gated.
  input.classList.add("enl-autosize");
  function autosize() {
    input.style.height = "auto";
    input.style.height = input.scrollHeight + "px";
  }
  function resetTextarea() {
    input.style.height = "";   // back to the CSS base (min-height) after submit
  }
  input.addEventListener("input", autosize);
  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      if (send.disabled) return;          // a turn is in flight
      submitQuestion((input.value || "").trim());
    }
    // Shift+Enter falls through to the default newline; autosize fires on input.
  });

  // ── Dynamic follow-up suggestions ───────────────────────────────────────
  // After a turn completes, replace the static starters with follow-ups derived
  // from the records the desk consulted THIS turn (read client-side from the
  // rendered tool widgets in the trace). The first turn (and any turn that
  // consulted no labeled records) keeps/falls back to the static starters, so
  // the prompt bar is never blank (rule 3).
  var promptsEl = document.getElementById("prompts");
  var staticPromptsHTML = promptsEl ? promptsEl.innerHTML : null;

  // Click-to-populate for a button.prompt (mirrors the static handler so
  // dynamically-rebuilt buttons behave identically): fill the box, then send.
  function wirePrompt(b) {
    b.addEventListener("click", function () {
      if (send.disabled) return;
      input.value = b.textContent.trim();
      autosize();
      submitQuestion(input.value);
    });
  }

  // Collect up to `max` distinct record labels from this turn's trace widgets.
  // Record labels surface as .enl-result__label / .enl-widget__head / the
  // subject/heading keys inside the tool result <details> bodies.
  function consultedLabels(traceEl, max) {
    if (!traceEl) return [];
    var sel = ".enl-result__label, .enl-widget__head, .enl-headings__key, .enl-prov__claim, .enl-edge__key";
    var nodes = traceEl.querySelectorAll(sel);
    var seen = {}, labels = [];
    for (var i = 0; i < nodes.length && labels.length < max; i++) {
      var txt = (nodes[i].textContent || "").trim();
      if (!txt) continue;
      if (txt.length > 80) txt = txt.slice(0, 77) + "…";  // keep buttons sane
      var k = txt.toLowerCase();
      if (seen[k]) continue;
      seen[k] = true;
      labels.push(txt);
    }
    return labels;
  }

  // Vary the phrasing so four suggestions don't read as a template dump.
  var FOLLOWUP_FORMS = [
    function (l) { return "Tell me more about " + l; },
    function (l) { return "What connects to " + l + "?"; },
    function (l) { return "Show the provenance for " + l; },
    function (l) { return "How does " + l + " fit the bigger picture?"; }
  ];

  function refreshFollowups(els) {
    if (!promptsEl) return;
    var labels = consultedLabels(els.trace, 4);
    if (!labels.length) {                   // nothing consulted → restore starters
      if (staticPromptsHTML !== null && promptsEl.innerHTML !== staticPromptsHTML) {
        promptsEl.innerHTML = staticPromptsHTML;
        promptsEl.querySelectorAll("button.prompt").forEach(wirePrompt);
      }
      return;
    }
    // Rebuild: a fresh label + the follow-up buttons (varied phrasing per label).
    promptsEl.innerHTML = "";
    var label = document.createElement("span");
    label.className = "label";
    label.textContent = "Follow up:";
    promptsEl.appendChild(label);
    labels.forEach(function (l, i) {
      var btn = document.createElement("button");
      btn.type = "button";
      btn.className = "prompt";
      btn.textContent = FOLLOWUP_FORMS[i % FOLLOWUP_FORMS.length](l);
      wirePrompt(btn);
      promptsEl.appendChild(btn);
    });
    thread.scrollTop = thread.scrollHeight;
  }
<% end %>
})();
</script>

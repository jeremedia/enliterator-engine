<p><%= link_to "← Status", root_path %></p>
<h1><%= @record.try(:title) || @record.try(:name) || "#{@type}/#{@record.id}" %></h1>
<p class="muted mono"><%= @type %>/<%= @record.id %></p>

<% if @contexts.any? %>
  <p class="muted samples">
    In contexts:
    <% @contexts.each do |c| %>
      <%= link_to c.name, root_path(context: c.key), class: "chip", style: "text-decoration:none" %>
    <% end %>
  </p>
<% end %>

<h2>Live claims <span class="muted" style="font-weight:400">(<%= @claims.size %>)</span></h2>
<div class="card">
  <% if @claims.any? %>
    <table>
      <tr><th>key</th><th>context</th><th>value</th><th>conf</th><th>status</th><th></th></tr>
      <% @claims.each do |c| %>
        <tr>
          <td><code><%= c.key %></code></td>
          <td class="samples"><%= c.context&.key || "root" %></td>
          <td><%= truncate(c.value.is_a?(String) ? c.value : c.value.to_json, length: 240) %></td>
          <td><%= c.confidence %></td>
          <td><span class="chip"><%= c.status %></span></td>
          <td><%= "🔒" if c.locked %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p class="muted">No live claims yet.</p>
  <% end %>
</div>

<% if @trajectories.any? %>
  <h2>Understanding over time <span class="muted" style="font-weight:400">— the compounding, visible</span></h2>
  <p class="muted samples" style="max-width:64ch">
    Each column is one tending visit; each row a claim. <span style="background:var(--accent-soft); padding:0 .3rem; border-radius:3px">Highlighted</span>
    cells changed from the prior visit — the record's understanding deepening (or not) in place.
  </p>
  <% @trajectories.each do |line| %>
    <div class="card" style="overflow-x:auto">
      <div><strong><%= line[:facet] %></strong>
        <span class="muted samples"><%= line[:steps].size %> visits</span></div>
      <table style="margin-top:.5rem; font-size:.82rem">
        <tr>
          <th style="min-width:8rem">claim</th>
          <% line[:steps].each do |step| %>
            <th style="min-width:12rem">
              <span class="muted"><%= step[:visit].created_at.strftime("%m-%d %H:%M") %></span>
              <span class="chip tier"><%= step[:visit].tier %></span><br>
              <span class="muted samples">
                conf <%= step[:confidence] %> ·
                +<%= step[:ops][:added].size %> ~<%= step[:ops][:updated].size %> =<%= step[:ops][:noop].size %><% if step[:ops][:deleted].any? %> −<%= step[:ops][:deleted].size %><% end %>
              </span>
            </th>
          <% end %>
        </tr>
        <% all_keys = line[:steps].flat_map { |s| s[:state].keys }.uniq.sort %>
        <% all_keys.each do |key| %>
          <tr>
            <td><code><%= key %></code></td>
            <% prev_claim = nil %>
            <% line[:steps].each do |step| %>
              <% claim = step[:state][key] %>
              <% changed = claim && prev_claim && claim.id != prev_claim.id %>
              <% appeared = claim && prev_claim.nil? && step != line[:steps].first %>
              <td class="samples" <% if changed || appeared %>style="background:var(--accent-soft)"<% end %>>
                <%= claim ? Enliterator::Trajectory.render(claim.value) : "—" %>
              </td>
              <% prev_claim = claim %>
            <% end %>
          </tr>
        <% end %>
      </table>
    </div>
  <% end %>
<% end %>

<h2>Recent visits</h2>
<div class="card">
  <% if @visits.any? %>
    <table>
      <tr><th>facet</th><th>context</th><th>tier</th><th>step</th><th>conf</th><th>status</th><th>applied</th><th>at</th></tr>
      <% @visits.each do |v| %>
        <tr class="<%= "warn-row" if v.model == "null" %>">
          <td><%= v.facet %></td>
          <td class="samples"><%= v.context&.key || "root" %></td>
          <td><%= v.tier %><% if v.model == "null" %> <span class="warn">null</span><% end %></td>
          <td><%= v.escalation_step %></td>
          <td><%= v.confidence %></td>
          <td><%= v.status %></td>
          <td><%= v.applied ? "✓" : "—" %></td>
          <td class="muted"><%= v.created_at&.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p class="muted">No visits yet.</p>
  <% end %>
</div>

<% if @measures.any? %>
  <h2>Measures</h2>
  <div class="card">
    <% @measures.each do |name, score| %>
      <div><strong><%= name %></strong>: <span class="mono"><%= score %></span></div>
    <% end %>
  </div>
<% end %>

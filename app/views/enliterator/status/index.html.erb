<% s = @synopsis %>
<h1>Status <span class="muted" style="font-weight:400; font-size:.95rem">— the collection's finding aid, maintained for itself</span></h1>
<p class="muted">
  A self-portrait: scope and content, the controlled vocabulary in use, the connection graph, and the
  health of the tending.
  <% if s[:models].any? %>Tended: <strong><%= s[:models].join(", ") %></strong>. <% end %>
  Drill into any record at <code>/status/&lt;Type&gt;/&lt;id&gt;</code>, or follow the source chips from <%= link_to "Chat", conversation_path %>.
</p>

<%# v0.13: where you are in the context tree + the lenses below this one %>
<% if current_context || @children.any? %>
  <div class="card" style="padding:.6rem 1.1rem">
    <span class="muted samples">viewing:</span>
    <%= link_to "whole collection", root_path(context: "root"), style: ("font-weight:600" unless current_context) %>
    <% current_context&.path&.each do |c| %>
      <span class="muted">›</span>
      <%= link_to c.name, root_path(context: c.key), style: ("font-weight:600" if c.id == current_context.id) %>
    <% end %>
    <% if @children.any? %>
      <span class="muted samples" style="margin-left:.75rem">within:</span>
      <% @children.each do |c| %>
        <%= link_to c.name, root_path(context: c.key), class: "chip", style: "text-decoration:none" %>
      <% end %>
    <% end %>
    <span class="muted samples" style="float:right"><%= link_to "tree →", contexts_path %></span>
  </div>
<% end %>

<%# v0.15: the heartbeat — what the next cycle would do, and what the last one did.
    Rendered only once a cycle has ever run (adoption-gated: no planner queries
    on hosts that haven't adopted; the page stays byte-identical to v0.14). %>
<% if @last_heartbeat %>
  <h2>Heartbeat <span class="muted" style="font-weight:400">— event-driven tending, on the ledger</span></h2>
  <div class="card">
    <% plan = @heartbeat_plan %>
    <div>
      <span class="muted samples">next cycle:</span>
      <% if plan.items.any? %>
        <% plan.counts.sort.each do |reason, n| %>
          <span class="chip"><%= reason %> <strong><%= n %></strong></span>
        <% end %>
        <span class="muted">est <%= number_with_delimiter(plan.est_total) %> of <%= number_with_delimiter(plan.budget) %> tokens</span>
      <% else %>
        <span class="muted">nothing to do — the collection is current</span>
      <% end %>
    </div>
    <div class="muted" style="margin-top:.35rem"><%= plan.horizon_line %></div>
    <% if plan.warnings.any? %>
      <details style="margin-top:.35rem"><summary class="muted samples"><%= plan.warnings.size %> planner note(s)</summary>
        <ul class="muted samples" style="margin:.3rem 0 0 1rem">
          <% plan.warnings.each do |w| %><li><%= w %></li><% end %>
        </ul>
      </details>
    <% end %>
    <div class="muted samples" style="margin-top:.5rem; border-top:1px solid var(--line); padding-top:.4rem">
      last cycle: #<%= @last_heartbeat.id %> · <%= @last_heartbeat.mode %> ·
      <%= @last_heartbeat.started_at.strftime("%Y-%m-%d %H:%M") %> ·
      <% if @last_heartbeat.finished? %>
        <% if @last_heartbeat.error %>
          <span class="warn">aborted — <%= @last_heartbeat.error %></span>
        <% else %>
          <%= (@last_heartbeat.executed || {}).map { |r, c| "#{r} #{c.reject { |_, v| v.to_i.zero? }.map { |k, v| "#{k} #{v}" }.join(', ')}" }.join(" · ") %>
          <% if @last_heartbeat.tokens_spent["total"] %>· <%= number_with_delimiter(@last_heartbeat.tokens_spent["total"]) %> tokens<% end %>
        <% end %>
      <% else %>
        <span class="warn">still open<%= " — likely crashed" if @last_heartbeat.started_at < 6.hours.ago %></span>
      <% end %>
    </div>
  </div>
<% end %>

<%# v0.17: the conservation report — what the shelf-read found, and what each
    pile needs. Adoption-gated: absent until a survey has ever run. %>
<% if @condition_adopted %>
  <h2>Condition <span class="muted" style="font-weight:400">— the conservation report: what the shelf-read found</span></h2>
  <div class="card">
    <% c = @condition %>
    <div>
      <span class="chip">surveyed <strong><%= number_with_delimiter(c[:surveyed]) %></strong> of <%= number_with_delimiter(c[:total]) %></span>
      <% if c[:untendable].positive? %>
        <span class="chip" style="background:#fdeceb; color:var(--warn)">untendable <strong><%= number_with_delimiter(c[:untendable]) %></strong></span>
        <span class="muted samples">— excluded from every tending queue until repaired</span>
      <% end %>
      <% if c[:residue_count].positive? %>
        <span class="chip">read but never understood <strong><%= c[:residue_count] %></strong></span>
      <% end %>
    </div>

    <% if c[:piles].any? || c[:residue_count].positive? %>
      <table style="margin-top:.6rem">
        <tr><th>pile</th><th>records</th><th>what's wrong</th><th>remediation <span class="muted samples">(probe)</span></th><th>treatment <span class="muted samples">(conservator)</span></th></tr>
        <% c[:piles].each do |pile| %>
          <% t = c[:treatments][pile[:signature]] %>
          <tr>
            <td class="mono" style="font-size:.78rem"><%= pile[:signature] %><br><span class="chip <%= 'tier' if pile[:band] == 'degraded' %>"><%= pile[:band] %></span></td>
            <td class="big" style="font-size:1.2rem"><%= number_with_delimiter(pile[:count]) %></td>
            <td class="samples"><%= pile[:failing].map { |probe, f| "#{probe}: #{f['note'] || f['code']}" }.join("; ") %>
              <% if t&.sample&.any? %><div class="muted samples" style="margin-top:.25rem">e.g. <%= t.sample.filter_map { |(_ty, _id, title)| title }.first(2).join(" · ") %></div><% end %></td>
            <td class="samples"><%= pile[:failing].values.filter_map { |f| f["remediation"] }.uniq.join(" / ").presence || "—" %></td>
            <td class="samples">
              <% if t&.diagnosis.present? %>
                <strong style="font-weight:600"><%= t.diagnosis %></strong><br><%= t.treatment %>
                <span class="muted samples">(conf <%= t.confidence&.round(2) %>)</span>
              <% else %><span class="muted">not yet assessed</span><% end %>
            </td>
          </tr>
        <% end %>
        <% if c[:residue_count].positive? %>
          <% t = c[:treatments][Enliterator::Condition::RESIDUE_SIGNATURE] %>
          <tr>
            <td class="mono" style="font-size:.78rem"><%= Enliterator::Condition::RESIDUE_SIGNATURE %><br><span class="chip">residue</span></td>
            <td class="big" style="font-size:1.2rem"><%= c[:residue_count] %></td>
            <td class="samples">condition sound; repeatedly read; zero derived claims — the engine could not understand these
              <% if t&.sample&.any? %><div class="muted samples" style="margin-top:.25rem">e.g. <%= t.sample.filter_map { |(_ty, _id, title)| title }.first(2).join(" · ") %></div><% end %></td>
            <td class="samples">—</td>
            <td class="samples">
              <% if t&.diagnosis.present? %>
                <strong style="font-weight:600"><%= t.diagnosis %></strong><br><%= t.treatment %>
              <% else %><span class="muted">not yet assessed</span><% end %>
            </td>
          </tr>
        <% end %>
      </table>
    <% else %>
      <div class="muted" style="margin-top:.5rem">Every surveyed record is sound — the shelf is clean.</div>
    <% end %>
  </div>
<% end %>

<%# v0.18: accuracy, measured — adoption-gated on any audit row. %>
<% if @audit_adopted %>
  <h2>Accuracy <span class="muted" style="font-weight:400">— the claim store, audited against its sources</span></h2>
  <div class="card">
    <% if @examiner_down %>
      <div class="warn" style="margin-bottom:.5rem">Examiner unavailable on the last cycle (Null adapter) — no new verdicts.</div>
    <% end %>
    <table>
      <tr><th>facet</th><th>tier</th><th>audited</th><th>supported rate</th><th>contradicted</th><th>unverifiable</th></tr>
      <% @audit_accuracy.each do |c| %>
        <tr>
          <td><%= c[:facet] %></td><td><%= c[:tier] %></td><td><%= c[:audited] %></td>
          <td><strong><%= c[:supported_rate] ? "#{(c[:supported_rate] * 100).round}%" : "—" %></strong></td>
          <td><%= c[:contradicted] %></td><td class="muted"><%= c[:unverifiable] %></td>
        </tr>
      <% end %>
    </table>
    <div class="muted samples" style="margin-top:.5rem">
      <% if @audit_agreement[:rate] %>
        examiner–human agreement <strong><%= (@audit_agreement[:rate] * 100).round %>%</strong> on <%= @audit_agreement[:overlaps] %> overlap(s)
      <% elsif @audit_agreement[:overlaps].positive? %>
        examiner–human: agreeing on <%= @audit_agreement[:agreements] %> of <%= @audit_agreement[:overlaps] %> — collecting
      <% else %>
        no human anchor yet — review verdicts on <%= link_to "Review", review_path %>
      <% end %>
      <% if @audit_agreement[:examiner_supported].to_i.positive? %>
        · humans overruled examiner-supported <%= @audit_agreement[:overruled_supported] %> of <%= @audit_agreement[:examiner_supported] %>
      <% end %>
      · <%= @audit_corrected %> claim(s) corrected
    </div>
  </div>
<% end %>

<h2>Facets</h2>
<div class="row">
  <% s[:facets].each do |st| %>
    <div class="card">
      <div><strong><%= st[:facet] %></strong> <span class="chip tier"><%= st[:tier] %></span></div>
      <div class="big"><%= st[:tended_count] %></div>
      <div class="muted" style="margin-top:-.3rem">records tended</div>
      <% if st[:vocabulary].any? %>
        <table style="margin-top:.6rem">
          <tr><th>term</th><th>live</th><th>e.g.</th></tr>
          <% st[:vocabulary].each do |v| %>
            <tr>
              <td><code><%= v[:key] %></code><% if v[:approved] %> <span class="chip" style="background:var(--accent-soft); color:var(--accent)" title="curator-approved; live but not yet codified">live</span><% end %></td>
              <td><%= v[:live_claims] %></td>
              <td class="samples"><%= v[:samples].first %></td>
            </tr>
          <% end %>
        </table>
      <% else %>
        <div class="muted samples">open vocabulary (no controlled terms)</div>
      <% end %>
    </div>
  <% end %>
</div>

<h2>Tending health <span class="muted" style="font-weight:400">— the smoke alarm</span></h2>
<div class="card">
  <table>
    <tr><th>facet</th><th>visits</th><th>adapters</th><th>escalation</th><th>empty-final</th><th>required-unmet</th></tr>
    <% s[:health].sort.each do |facet, b| %>
      <% null_n = b[:adapter_mix]["null"].to_i %>
      <tr class="<%= "warn-row" if null_n.positive? %>">
        <td><%= facet %></td>
        <td><%= b[:total] %></td>
        <td class="mono">
          <%= b[:adapter_mix].map { |m, n| "#{m}=#{n}" }.join("  ") %>
          <% if null_n.positive? %><span class="warn">⚠ null adapter ran <%= null_n %> visit(s)</span><% end %>
        </td>
        <td><%= b[:escalation_rate] %></td>
        <td><%= b[:empty_final_rate] %></td>
        <td><%= b[:required_unmet] %></td>
      </tr>
    <% end %>
  </table>
</div>

<% if s[:connections].any? %>
  <h2>Connection graph</h2>
  <div class="card">
    <table>
      <tr><th>link key</th><th>live</th><th>e.g.</th></tr>
      <% s[:connections].each do |c| %>
        <tr><td><code><%= c[:key] %></code></td><td><%= c[:live_claims] %></td><td class="samples"><%= c[:samples].first %></td></tr>
      <% end %>
    </table>
  </div>
<% end %>

<% if s[:gaps].any? %>
  <h2>Vocabulary gaps <span class="muted" style="font-weight:400">— proposed, awaiting review</span>
    <span style="font-weight:400; font-size:.85rem">· <%= link_to "Review all →", suggestions_path %></span></h2>
  <div class="card">
    <table>
      <tr><th>proposed key</th><th>records</th><th>rationale</th></tr>
      <% s[:gaps].each do |g| %>
        <tr><td><code><%= g[:proposed_key] %></code></td><td><%= g[:count] %></td><td class="samples"><%= g[:sample_rationale] %></td></tr>
      <% end %>
    </table>
  </div>
<% end %>
